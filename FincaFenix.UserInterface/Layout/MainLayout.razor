@inherits LayoutComponentBase
@inject TextAppBarState TextApp

<MudThemeProvider Theme="CustomTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<PageTitle>Finca Fenix</PageTitle>

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="fa-solid fa-bars" 
            Color="Color.Tertiary" 
            Edge="Edge.Start" 
            OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-2">@TextApp.PageTitle</MudText>
        <MudSpacer/>
        <MudButton Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.Add" Color="Color.Info" Size="Size.Small" >Crear órden</MudButton>
    </MudAppBar>
    <MudDrawer Class="mud-height-full" MiniWidth="70px" Color="Color.Secondary" @bind-Open="_drawerOpen" Elevation="3" Height="100vh"
               ClipMode="_clipMode" Variant="@DrawerVariant.Mini" Breakpoint="@_breakpoint">
               <NavMainMenu/>
    </MudDrawer>
    <MudMainContent>
        <MudContainer Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
@((RenderFragment)(builder => base.BuildRenderTree(builder)))

@code {
    private Breakpoint _breakpoint = Breakpoint.Xs;
    private DrawerClipMode _clipMode = DrawerClipMode.Never;
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
    protected override void OnInitialized()
    {
        TextApp.OnChange += StateHasChanged;
    }
    public void Dispose()
    {
        TextApp.OnChange -= StateHasChanged;
    }
    MudTheme CustomTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = Colors.Teal.Darken4,
            AppbarBackground = Colors.Teal.Darken4,
            Secondary = Colors.Teal.Darken3,
            Tertiary = Colors.Gray.Lighten5,
            Info = Colors.BlueGray.Default
        }
    };
}
