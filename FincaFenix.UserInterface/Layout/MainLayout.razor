@inherits LayoutComponentBase
@inject TextAppBarState TextAppBar
@inject NavigationManager NavManager

<MudThemeProvider Theme="CustomTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<PageTitle>Finca Fenix</PageTitle>

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="fa-solid fa-bars" 
            Color="Color.Tertiary" 
            Edge="Edge.Start" 
            OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-2">@TextAppBar.PageTitle</MudText>
        <MudSpacer/>
        @if (_showAddOrderButton){
             <MudButton Variant="Variant.Filled"
                       EndIcon="@Icons.Material.Filled.Add"
                       Color="Color.Info"
                       Size="Size.Small">crear orden</MudButton>
        }
    </MudAppBar>
    <MudDrawer Class="mud-height-full" MiniWidth="70px" Color="Color.Secondary" @bind-Open="_drawerOpen" Elevation="3" Height="100vh"
               ClipMode="_clipMode" Variant="@DrawerVariant.Mini" Breakpoint="@_breakpoint">
               <NavMainMenu/>
    </MudDrawer>
    <MudMainContent>
        <MudContainer Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
@((RenderFragment)(builder => base.BuildRenderTree(builder)))


