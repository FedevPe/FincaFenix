<MudGrid>
    <MudItem xs="12" sm="6">
        @foreach (var sector in SectorColumn1)
        {
            <MudCheckBox T="bool" Label="@sector.Name" @bind-Checked="sector.Selected"
                         Color="Color.Primary" />
        }
    </MudItem>
    <MudItem xs="12" sm="6">
        @foreach (var sector in SectorColumn2)
        {
            <MudCheckBox T="bool" Label="@sector.Name" @bind-Checked="sector.Selected"
                         Color="Color.Primary" />
        }
    </MudItem>
</MudGrid>

@code {
    [Parameter] public List<SectorDTO> SectorList { get; set; } = new();
    [Parameter] public EventCallback<List<SectorDTO>> SelectedSectorChanged { get; set; }

    private List<SectorDTO> SectorColumn1 => SectorList.Where((s, i) => i % 2 == 0).ToList();
    private List<SectorDTO> SectorColumn2 => SectorList.Where((s, i) => i % 2 != 0).ToList();

    private async Task OnSelectionChanged()
    {
        var seleccionados = SectorList.Where(s => s.Selected).ToList();
        await SelectedSectorChanged.InvokeAsync(seleccionados);
    }
}
