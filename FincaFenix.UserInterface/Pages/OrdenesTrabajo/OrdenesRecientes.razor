@page "/ordenesRecientes"
@inject TextAppBarState TextApp


<div class="mt-3 mb-3">
    <MudGrid Justify="Justify.FlexEnd" Class="mb-2 g-3">
        <MudItem>
            <MudButton @onclick="OpenDialog" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add">Nueva Orden</MudButton>
        </MudItem>
    </MudGrid>
</div>
<SearchBar />
<div class="container-fluid shadow p-3 border rounded mt-3 mb-3">
    <MudText Typo="Typo.h5"><b>Ordenes recientes</b></MudText>
    <MudDivider Class="my-2" Style="border-color: black;" />
    <MudGrid Spacing="3" Justify="Justify.FlexStart" Class="mt-1">
        <MudItem xs="12" lg="3">
            <OrdenCard NumOrden="603" Finca="San Carlos" Tarea="Aplicación de fertilizantes" />
        </MudItem>
        <MudItem xs="12" lg="3">
            <OrdenCard NumOrden="604" Finca="Goudge" Tarea="Tratamiento Fitosanitario" />
        </MudItem>
        <MudItem xs="12" lg="3">
            <OrdenCard NumOrden="605" Finca="Las Aguaditas" Tarea="Aplicación de herbicida" />
        </MudItem>
        <MudItem xs="12" lg="3">
            <OrdenCard NumOrden="603" Finca="San Carlos" Tarea="Aplicación de fertilizantes" />
        </MudItem>
    </MudGrid>
    <div class="w-100 d-flex flex-column align-items-center mt-4">
        <MudPagination Variant="Variant.Filled" Count="3" />
    </div>
</div>

 
@code {
    [Inject] private DialogFactoryService DialogFactory { get; set; } = default!;

    protected override void OnInitialized()
    {
        TextApp.PageTitle = "Ordenes de Trabajo";
    }
    private async Task OpenDialog()
    {
        await DialogFactory.ShowFormDialogAsync<CreateOrderForm>("Nueva orden de trabajo");
    }
}
