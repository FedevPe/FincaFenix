@page "/createOrder"

<NewOrderData ViewModel=OrderDataViewModel/>
<NewRecipe ViewModel=NewRecipeViewModel/>
<div class="container-fluid shadow mt-3 rounded bg-color-white p-2 mb-4">
    <MudGrid Spacing="1" Justify="Justify.FlexEnd">
        <MudItem>
            <MudButton Href="/ordenesRecientes"
                       Variant="Variant.Filled"
                       Color="Color.Error"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Cancel">Cancelar</MudButton>
        </MudItem>
        <MudItem>
            <MudButton Href="/ordenesRecientes"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Save">Guardar</MudButton>
        </MudItem>
    </MudGrid>
</div>

@code {
    [Inject] InfoNewWorkOrderViewModel OrderDataViewModel { get; set; } = default!;
    [Inject] NewRecipeViewModel NewRecipeViewModel { get; set; } = default!;
    [Inject] CreateWorkOrderViewModel CreateWorkOrderViewModel { get; set; } = default!;

    private List<DetailSectorFarmDTO> SelectedSectorList { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await OrderDataViewModel.LoadInitializeAsync();
        await NewRecipeViewModel.LoadInitializeAsync();
    }

    private void ActualizarSectoresSeleccionados(List<DetailSectorFarmDTO> sectores)
    {
        SelectedSectorList = sectores;
        StateHasChanged();
    }
    private async Task SaveWorkOrder()
    {
        var nuevaOrden = new WorkOrderDTO
        {
            FarmId = OrderDataViewModel.SelectedFarmId,
            TaskId = OrderDataViewModel.SelectedTaskId,
            StartDate = DateTime.Now,
            Description = OrderDataViewModel.Description,
            SectorList = OrderDataViewModel.SelectedSectors.Select(s => s.Id).ToList(),
            Recipe = new RecipeWorkOrderDTO
            {
                MachineId = NewRecipeViewModel.MachineId,
                Dose = NewRecipeViewModel.Dose,
                DoseUnit = NewRecipeViewModel.DoseUnit,
                Details = NewRecipeViewModel.Details.Select(m => new DetailRecipeDTO
                {
                    CategoryId = m.CategoryId,
                    MaterialId = m.MaterialId,
                    CantRequerida = m.CantRequerida,
                    CantEstimada = m.CantEstimada,
                    UnidadCantRequerida = m.UnidadCantRequerida,
                    UnidadCantEstimada = m.UnidadCantEstimada
                }).ToList()
            },
        };

        await CreateWorkOrderViewModel.SaveWorkOrder(nuevaOrden); // Este método debería llamar al controlador que interactúa con el interactor
    }

}
