@page "/createOrder"
@using FincaFenix.ViewModels.ViewModels

<NewOrderData InfoViewModel=InfoViewModel/>
<NewRecipe/>
<div class="container-fluid shadow mt-3 rounded bg-color-white p-2">
    <MudGrid Spacing="1" Justify="Justify.FlexEnd">
        <MudItem>
            <MudButton Href="/ordenesRecientes"
                       Variant="Variant.Filled"
                       Color="Color.Error"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Cancel">Cancelar</MudButton>
        </MudItem>
        <MudItem>
            <MudButton Href="/ordenesRecientes"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Save">Guardar</MudButton>
        </MudItem>
    </MudGrid>
</div>

@code {
    [Inject] InfoCreateOrderViewModel InfoViewModel { get; set; } = default!;

    private List<DetailSectorFarmDTO> SelectedSectorList { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await InfoViewModel.LoadInitializeAsync();
    }

    private void ActualizarSectoresSeleccionados(List<DetailSectorFarmDTO> sectores)
    {
        SelectedSectorList = sectores;
        StateHasChanged();
    }
}
