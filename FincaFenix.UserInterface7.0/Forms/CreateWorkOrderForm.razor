@page "/createOrder"

<PageTitle>Nueva orden de trabajo</PageTitle>

<MudForm @ref="createWorkOrderForm" Model="CreateWorkOrderViewModel" Validation="@(Validator.ValidateValue)">
    <NewOrderData ViewModel=CreateWorkOrderViewModel.OrderData />
    <NewRecipe ViewModel=CreateWorkOrderViewModel.RecipeData />

    <div class="container-fluid mt-3 mb-4">
        <div class="card shadow-sm rounded" style="background-color: #ffffff; border: none;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-circle me-3" style="width: 40px; height: 40px; background: linear-gradient(135deg, #00796B 0%, #004d47 100%); color: white; border-radius: 6px; display: flex; align-items: center; justify-content: center;">
                        <MudIcon Icon="@Icons.Material.Filled.Description" style="width: 30px; height: 30px;" />
                    </div>
                    <MudText Typo="Typo.h6" Style="color: #1a202c; font-weight: 700; margin: 0;">Descripción</MudText>
                </div>
                <MudGrid Justify="Justify.Center">
                    <MudItem lg="12" xs="12">
                        <MudTextField T="string"
                                      @bind-Value="CreateWorkOrderViewModel.WorkOrder.Description"
                                      Placeholder="Ingrese una descripción de la orden"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      Lines="3"
                                      Style="border-radius: 8px;"
                                      For="@(() => CreateWorkOrderViewModel.WorkOrder.Description)" />
                    </MudItem>
                </MudGrid>
            </div>
        </div>
    </div>
</MudForm>
<div class="container-fluid mt-3 mb-4">
    <div class="card shadow-sm rounded" style="background-color: #ffffff; border: none;">
        <div class="card-body p-3">
            <MudGrid Spacing="2" Justify="Justify.FlexEnd" AlignItems="Center.Center">
                <MudItem>
                    <MudButton Href="/ordenestrabajo"
                               Variant="Variant.Outlined"
                               Color="Color.Default"
                               Size="Size.Medium"
                               StartIcon="@Icons.Material.Filled.Cancel"
                               Style="border-color: #dc3545; color: #dc3545; border-radius: 8px; padding: 8px 24px; font-weight: 500; text-transform: none;">
                        Cancelar
                    </MudButton>
                </MudItem>
                <MudItem>
                    <MudButton OnClick="(async () => await SaveWorkOrder())"
                               Variant="Variant.Filled"
                               Size="Size.Medium"
                               StartIcon="@Icons.Material.Filled.Save"
                               Style="background: linear-gradient(135deg, #00796B 0%, #004d47 100%); color: white; border-radius: 8px; padding: 8px 24px; font-weight: 500; text-transform: none; box-shadow: 0 2px 4px rgba(27, 94, 32, 0.2);">
                        Guardar
                    </MudButton>
                </MudItem>
            </MudGrid>
        </div>
    </div>
</div>


