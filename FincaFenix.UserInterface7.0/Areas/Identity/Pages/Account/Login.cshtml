@page "/login"
@model LoginModel
@using FincaFenix.Entities.POCOEntities
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    Layout = "_Layout";
    ViewData["Title"] = "Iniciar Sesion";
}

<div class="login-page-login mt-6">
    <div class="login-card-login">
        <!-- Logo Section -->
        <div class="logo-section-login">
            <div class="logo-circle-login">
                <img src="logo.png" alt="Logo de FincaFenix" class="img-logo-login"/>
            </div>
        </div>

        <!-- Welcome Section -->
        <div class="welcome-section-login">
            <h1 class="welcome-title-login">@ViewData["Title"]</h1>
            <p class="welcome-subtitle-login">Ingrese sus credenciales para acceder al sistema</p>
        </div>

        <!-- Form Section -->
        <form id="account" method="post" class="form-section-login">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Login.UserName" class="form-control" aria-required="true" placeholder="Usuario" />
                <label asp-for="Login.UserName" class="form-label">Usuario</label>
                <span asp-validation-for="Login.UserName" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Login.Password" class="form-control" aria-required="true" placeholder="password" />
                <label asp-for="Login.Password" class="form-label">Contraseña</label>
                <span asp-validation-for="Login.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" asp-for="RememberUser" />
                <label class="form-check-label" asp-for="RememberUser">
                    @Html.DisplayNameFor(m => m.RememberUser)
                </label>
            </div>

            <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Iniciar sesión</button>

            <!-- Error Message -->
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger mt-3" role="alert">
                    @Model.ErrorMessage
                </div>
            }
        </form>

        <!-- Links Section -->
        @* <div class="mt-4 text-center">
            <p><a id="forgot-password" asp-page="./ForgotPassword">¿Olvidaste tu contraseña?</a></p>
            <p><a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Registrarse como nuevo usuario</a></p>
        </div> *@

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
<style>
    .login-page-login {
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        padding: 20px;
    }

    .login-card-login {
        background: white;
        border-radius: 20px;
        padding: 40px 30px;
        box-shadow: 0 10px 15px rgba(0, 0, 0, 0.17);
        width: 100%;
        max-width: 400px;
        position: relative;
    }

    .logo-section-login {
        display: flex;
        justify-content: center;
        margin-bottom: 10px;
        position: relative;
        top: -20px;
    }

    .logo-circle-login {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: white;
        border: 1px solid #e0e0e0;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
    }

    .img-logo-login {
        width: 250px;
        height: 250px;
        border-radius: 50%;
        margin-bottom: 20px;
        box-shadow: 0 0px 15px rgba(0, 0, 0, 0.15);
    }

    .welcome-section-login {
        text-align: center;
        margin-bottom: 10px;
        margin-top: 50px;
    }

    .welcome-title-login {
        color: #333;
        font-weight: 600;
        font-size: 30px;
    }

    .welcome-subtitle-login {
        color: #666;
        font-size: 14px;
    }

    .form-section-login {
        margin-bottom: 20px;
    }

    .login-field-login {
        margin-bottom: 20px;
        color: black;
    }

    .login-button-login {
        margin-top: 10px;
        height: 50px;
        border-radius: 8px;
        background-color: #00695c !important;
        font-weight: 500;
        text-transform: none;
    }

    .login-button:hover {
        background-color: #004d40 !important;
    }

    .error-alert-login {
        margin-top: 20px;
        border-radius: 8px;
    }

    /* Responsive Design */
    @@media (max-width: 480px) {
        .login-card-login {
            padding: 30px 20px;
            margin: 10px;
        }

        .logo-circle-login {
            width: 80px;
            height: 80px;
        }

        .logo-text-login {
            font-size: 1.2rem;
        }
    }
</style>