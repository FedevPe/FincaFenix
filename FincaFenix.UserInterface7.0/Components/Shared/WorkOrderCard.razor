<MudCard Class="info-card h-100" Elevation="3">
    <MudCardContent Class="card-header pa-4 rounded-t-lg">
        <div class="d-flex align-center justify-space-between ">
            <div>
                <MudText Typo="Typo.h5" Class="card-title mb-1">
                    Orden N° @InfoWO.OrderNum
                </MudText>
                <MudText Typo="Typo.body2" Class="card-subtitle">
                    Finca @InfoWO.Farm.Name
                </MudText>
            </div>
            <MudIcon Icon="fa-solid fa-seedling"
                     Class="header-icon"
                     Size="Size.Medium"/>
        </div>
    </MudCardContent>
    
    <MudDivider Class="custom-divider" />
    
    <MudCardContent Class="card-body pa-4">
        <div class="d-flex flex-column align-start">
            <div class="d-flex">
                <MudIcon Icon="fa-solid fa-clipboard"
                         Size="Size.Small"
                         Color="Color.Info"
                         Class="content-icon me-2" />
                <MudText Typo="Typo.body1" Class="content-text">
                    @InfoWO.Task.Description
                </MudText>
            </div>
            <div class="d-flex mt-1">
                <MudIcon Icon="fa-solid fa-calendar"
                         Size="Size.Small"
                         Color="Color.Primary"
                         Class="content-icon me-2" />
                <MudText Typo="Typo.body1" Class="content-text">
                    @InfoWO.CreatedDate.Value.ToShortDateString()
                </MudText>
            </div>
            <MudGrid Class="mt-1" Justify="Justify.FlexStart" Spacing="0">
                <MudItem>
                    <MudChip T="string"
                            Color="ColorText"
                            Variant="Variant.Filled"
                            Size="Size.Small"
                            Class="status-chip"
                            Label="true"
                            Style="color: black">
                        @InfoWO.Status
                    </MudChip>
                </MudItem>  
                <MudItem>
                    <div class="cell-content sectors-content">
                        @if (InfoWO.SectorList != null && InfoWO.SectorList.Any())
                        {
                            @foreach (var sector in InfoWO.SectorList.Take(3))
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info" Class="sector-chip">
                                    @sector.SectorName
                                </MudChip>
                            }
                            @if (InfoWO.SectorList.Count() > 5)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default" Class="sector-chip">
                                    +@(InfoWO.SectorList.Count() - 3)
                                </MudChip>
                            }
                        }
                        else
                        {
                            <span class="no-sectors">Sin cuadros</span>
                        }
                    </div>
                </MudItem>
            </MudGrid>
        </div>
    </MudCardContent>
    
    <MudCardActions Class="card-actions pa-3 d-flex justify-content-center align-items-center">
        <MudGrid Justify="Justify.Center" Spacing="3">
            <MudItem>
                <MudButton Variant="Variant.Text"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Visibility"
                           Class="action-button"
                           Color="Color.Info"
                           IconColor="Color.Info"
                           OnClick="OpenWorkOrderDetails">Ver Detalles</MudButton>
            </MudItem>
            <MudItem>
                <MudButton Variant="Variant.Text"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.AddTask"
                           Class="action-button"
                           Color="Color.Secondary"
                           IconColor="Color.Secondary"
                           onclick="OpenActivityForm">Registrar Actividad</MudButton>
            </MudItem>
        </MudGrid>
    </MudCardActions>    
</MudCard>

@code {
    [Parameter] public ShowWorkOrderDTO InfoWO { get; set; }

    private MudBlazor.Color ColorText => InfoWO.Status switch
    {
        "Cerrado" => MudBlazor.Color.Error,
        "Pendiente" => MudBlazor.Color.Warning,
        "Activo" => MudBlazor.Color.Secondary,
        _ => MudBlazor.Color.Default
    };

    [Inject] private NavigationManager NavigationManager { get; set; }
    [Inject] private ISnackbar Snackbar { get; set; }

    public void OpenActivityForm()
    {
        if (InfoWO.Status == "Activo")
        {
            NavigationManager.NavigateTo($"/actividad/registrar/{InfoWO.Id}");
        }
        else
        {
            Snackbar.Add($"La orden de trabajo N° {InfoWO.OrderNum} no se encuentra activa.", MudBlazor.Severity.Info);
        }
    }
    public void OpenWorkOrderDetails()
    {
        NavigationManager.NavigateTo($"/ordentrabajo/{InfoWO.Id}/detalle/");
    }
}

<style>
    .cell-content {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .sectors-content {
        flex-wrap: wrap;
        gap: 0.25rem;
    }
    .info-card {
        border-radius: 12px;
        border: 1px solid rgba(0, 0, 0, 0.08);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
    }
    .info-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 1px 1px rgba(0, 0, 0, 0.15) !important;
    }
    .card-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 12px 12px 0 0;
    }
    .card-title {
        font-weight: 600;
        color: #2c3e50;
        letter-spacing: -0.5px;
    }
    .card-subtitle {
        color: #6c757d;
        font-weight: 500;
    }
    .header-icon {
        color: #28a745;
        opacity: 0.8;
    }
    .custom-divider {
        height: 5px;
        background: linear-gradient(90deg, transparent, #dee2e6, transparent);
    }
    .card-body {
        padding: 1.5rem !important;
        height: 100%;
    }
    .content-icon {
        color: #17a2b8;
    }
    .content-text {
        color: #495057;
        font-weight: 500;
    }
    .card-actions {
        background-color: #f8f9fa;
        border-radius: 0 0 12px 12px;
        border-top: 1px solid rgba(0, 0, 0, 0.05);
        width: 100%;
    }
    .action-button {
        color: #004D40;
        font-weight: 500;
        text-transform: none;
    }
    .action-button:hover {
        background-color: rgba(0, 123, 255, 0.04);
    }
    .info-card:focus-within {
        outline: 2px solid #004D40;
        outline-offset: 2px;
    }
    .status-chip {
        border: 1px solid;
        color: white !important;
    }

    .sector-chip {
        margin: 0.125rem;
        font-size: 0.75rem;
        height: 24px;
    }
</style>

