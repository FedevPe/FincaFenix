<div class="container-fluid shadow p-3 border rounded mb-1 bg-color-white">
    <div class="d-flex justify-content-center align-item-center bg-color-white">
        <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Large" />
        <MudText Typo="Typo.h5"><b>Filtros de busqueda</b></MudText>
        <MudSpacer />
        <MudIconButton Icon="@mudIcon" Size="Size.Medium" OnClick="OnExpandCollapseClick" Style="color: black; font-size: 5px">@(_expanded ? "Collapse" : "Expand")</MudIconButton>
    </div>
    <MudDivider Class="my-1" Style="border-color: black;" />
    <div>
        <MudGrid Justify="Justify.FlexStart" Class="mb-2">
            <MudItem xs="6" lg="6">
                <MudTextField @bind-Value="Search" Label="Buscar por n° de orden..." Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem lg="2" Class="mt-2">
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Search" Color="Color.Primary" Size="Size.Medium" OnClick="ApplyFilter" />
            </MudItem>
        </MudGrid>
        <MudCollapse Expanded="_expanded">
            <MudGrid Spacing="4" Justify="Justify.FlexStart" Class="mt-4 g-2">
                <MudItem xs="12" lg="4">
                    <MudSelect @bind-Value="_selectedFinca"
                               Label="Finca"
                               Margin="Margin.Dense"
                               Variant="Variant.Outlined"
                               Clearable
                               Adornment="Adornment.End"
                               AdornmentIcon="@Icons.Material.Filled.LocationOn"
                               AdornmentColor="Color.Error"
                               ShrinkLabel
                               AnchorOrigin="Origin.BottomCenter"
                               TransformOrigin="Origin.TopCenter" Style="z-index: auto;">
                        <MudSelectItem T="int" Value="0" Disabled="true">Seleccione una finca</MudSelectItem>
                        @foreach (var item in ViewModel.Farms)
                        {
                            <MudSelectItem T="int" Value="@item.Id">@item.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" lg="4">
                    <MudSelect @bind-Value="_selectedTask"
                               Label="Tarea"
                               Margin="Margin.Dense"
                               Variant="Variant.Outlined"
                               Clearable
                               Adornment="Adornment.End"
                               AdornmentIcon="@Icons.Material.Filled.Dashboard"
                               AdornmentColor="Color.Info"
                               ShrinkLabel
                               AnchorOrigin="Origin.BottomCenter"
                               TransformOrigin="Origin.TopCenter" Style="z-index: auto;">
                        <MudSelectItem T="int" Value="0" Disabled="true">Seleccione una tarea</MudSelectItem>
                        @foreach (var item in ViewModel.Tasks)
                        {
                            <MudSelectItem T="int" Value="@item.Id">@item.Description</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" lg="4">
                    <MudSelect @bind-Value="_selectedState"
                               Label="Estado"
                               Margin="Margin.Dense"
                               Variant="Variant.Outlined"
                               Clearable
                               Adornment="Adornment.End"
                               AdornmentIcon="@Icons.Material.Filled.PendingActions"
                               AdornmentColor="Color.Warning"
                               ShrinkLabel
                               AnchorOrigin="Origin.BottomCenter"
                               TransformOrigin="Origin.TopCenter" Style="z-index: auto;">
                        <MudSelectItem T="string" Value=@("Activo")>Activo</MudSelectItem>
                        <MudSelectItem T="string" Value=@("Pendiente")>Pendiente</MudSelectItem>
                        <MudSelectItem T="string" Value=@("Cerrado")>Cerrado</MudSelectItem>
                    </MudSelect>

                </MudItem>
                <MudItem xs="12" lg="6">
                    <MudDateRangePicker @ref="_picker" Label="Fecha" @bind-DateRange="_dateRange"
                                        AutoClose="true" PickerVariant="PickerVariant.Dialog"
                                        Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Dark">
                        <PickerActions>
                            <MudButton Class="mr-auto align-self-start" OnClick="@(() => _picker.ClearAsync())">Eliminar</MudButton>
                            <MudButton OnClick="@(() => _picker.CloseAsync(false))">Cancelar</MudButton>
                            <MudButton Color="Color.Primary" OnClick="@(() => _picker.CloseAsync())">Ok</MudButton>
                        </PickerActions>
                    </MudDateRangePicker>
                </MudItem>
            </MudGrid>
        </MudCollapse>
    </div>
</div>

@code {
    private string mudIcon = "fa-solid fa-chevron-down";
    private bool _expanded = false;
    private int _selectedFinca = 0;
    private int _selectedTask = 0;
    private string _selectedState = string.Empty;
    private MudDateRangePicker _picker;
    private DateRange _dateRange = new DateRange();

    [Inject] private SearchBarViewModel ViewModel { get; set; }

    [Parameter] public string Search { get; set; }
    [Parameter] public EventCallback<SearchBarViewModel> OnSearch { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await ViewModel.LoadInitializeAsync();
    }

    // Método que se llama al hacer clic en el botón de búsqueda
    private async Task ApplyFilter()
    {
        // Creamos un objeto con todos los filtros
        ViewModel.SearchTerm = Search;
        ViewModel.FincaId = _selectedFinca;
        ViewModel.TaskId = _selectedTask;
        ViewModel.State = _selectedState;
        ViewModel.StartDate = _dateRange.Start;
        ViewModel.EndDate = _dateRange.End;

        // Invocamos el EventCallback y pasamos el objeto de filtro
        await OnSearch.InvokeAsync(ViewModel);
    }

    void OnExpandCollapseClick()
    {
        _expanded = !_expanded;

        if (_expanded)
        {
            mudIcon = "fa-regular fa-square-caret-up";
        }
        else
        {
            mudIcon = "fa-regular fa-square-caret-down";
        }
    }
}
