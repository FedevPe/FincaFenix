<div class="mx-3">
    <div class="statsSector-card statsSector-card-active @(SectorFarmDTO.Id == SectorSelectedId ? "active" : "")" @onclick="() => SetSectorSelected(SectorFarmDTO.Id)">
        <MudPaper Elevation="2" Class="statsSector-paper">
            <div class="statsSector-content">
                <div class="statsSector-icon-wrapper statsSector-icon-created">
                    <MudIcon Icon="@Icons.Material.Filled.Fullscreen" Class="statsSector-icon" />
                </div>
                <div class="statsSector-info">
                    <MudText Class="statsSector-title" Typo="Typo.subtitle2">Cuadro</MudText>
                    <MudText Class="statsSector-number statsSector-number-active" Typo="Typo.h4">@SectorFarmDTO.SectorName</MudText>
                    <MudText Class="trend-text" Typo="Typo.h4">@SectorFarmDTO.Area ha</MudText>
                </div>
            </div>
            <div class="statsSector-trend">
                <MudIcon Icon="@Icons.Material.Filled.Info" Class="trend-icon trend-created" />
                <span class="trend-text">@SectorFarmDTO.FruitName - @SectorFarmDTO.VarietyName</span>
            </div>
        </MudPaper>
    </div>
</div>
@code{
    [Parameter] public DetailSectorFarmDTO SectorFarmDTO { get; set; }
    [Parameter] public int SectorSelectedId { get; set; }
    [Parameter] public EventCallback<int> OnSectorSelectedChanged { get; set; }

    private async Task SetSectorSelected(int id)
    {
        await OnSectorSelectedChanged.InvokeAsync(id);
    }
}
<style>
    .statsSector-card {
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 16px;
        overflow: hidden;
        position: relative;
    }

    .statsSector-paper {
        padding: 1.5rem ;
        border-radius: 16px ;
        background: white ;
        border: 1px solid rgba(0, 0, 0, 0.06) ;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) ;
    }

    .statsSector-card:hover .statsSector-paper {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15) ;
    }

    .statsSector-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--card-gradient-start), var(--card-gradient-end));
        opacity: 0;
        transition: opacity 0.3s ease;
        z-index: 1;
    }

    .statsSector-card:hover::before {
        opacity: 1;
    }

    .statsSector-card.active::before {
        opacity: 1;
    }

    .statsSector-card.active .statsSector-paper {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15) ;
    }

    .statsSector-content {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .statsSector-icon-wrapper {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

        .statsSector-icon-wrapper::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, var(--icon-bg-start), var(--icon-bg-end));
            opacity: 0.1;
        }

    .statsSector-icon {
        font-size: 28px ;
        color: var(--icon-color) ;
        z-index: 1;
        position: relative;
    }

    .statsSector-info {
        flex: 1;
    }

    .statsSector-title {
        color: #64748b ;
        font-weight: 500 ;
        margin-bottom: 0.25rem ;
        font-size: 0.875rem ;
    }

    .statsSector-number {
        font-weight: 700 ;
        margin: 0 ;
        line-height: 1.2 ;
    }

    .statsSector-trend {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding-top: 0.75rem;
        border-top: 1px solid rgba(0, 0, 0, 0.06);
    }

    .trend-icon {
        font-size: 16px ;
    }

    .trend-text {
        font-size: 0.75rem;
        color: #64748b;
        font-weight: 500;
    }

    /* Colores específicos para cada tipo de tarjeta */
    .statsSector-card-created {
        --card-gradient-start: #3b82f6;
        --card-gradient-end: #1d4ed8;
        --icon-bg-start: #3b82f6;
        --icon-bg-end: #1d4ed8;
        --icon-color: #3b82f6;
    }

    .statsSector-number-created {
        color: #3b82f6 ;
    }

    .statsSector-card-active {
        --card-gradient-start: #10b981;
        --card-gradient-end: #059669;
        --icon-bg-start: #10b981;
        --icon-bg-end: #059669;
        --icon-color: #10b981;
    }

    .statsSector-number-active {
        color: #10b981 ;
    }

    .statsSector-card-pending {
        --card-gradient-start: #f59e0b;
        --card-gradient-end: #d97706;
        --icon-bg-start: #f59e0b;
        --icon-bg-end: #d97706;
        --icon-color: #f59e0b;
    }

    .statsSector-number-pending {
        color: #f59e0b ;
    }

    .statsSector-card-closed {
        --card-gradient-start: #ef4444;
        --card-gradient-end: #dc2626;
        --icon-bg-start: #ef4444;
        --icon-bg-end: #dc2626;
        --icon-color: #ef4444;
    }

    .statsSector-number-closed {
        color: #ef4444 ;
    }

    .trend-created {
        color: #3b82f6 ;
    }

    .trend-up {
        color: #10b981 ;
    }

    .trend-down {
        color: #f59e0b ;
    }

    .trend-completed {
        color: #ef4444 ;
    }

    /* Responsive adjustments */
    @@media (max-width: 960px) {
        .statsSector-paper {
            padding: 1.25rem ;
        }

        .statsSector-content {
            gap: 0.75rem;
        }

        .statsSector-icon-wrapper {
            width: 50px;
            height: 50px;
        }

        .statsSector-icon {
            font-size: 24px ;
        }
    }

    /* Animaciones */
    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .statsSector-card {
        animation: slideUp 0.6s ease-out;
    }

        .statsSector-card:nth-child(1) {
            animation-delay: 0.1s;
        }

        .statsSector-card:nth-child(2) {
            animation-delay: 0.2s;
        }

        .statsSector-card:nth-child(3) {
            animation-delay: 0.3s;
        }

        .statsSector-card:nth-child(4) {
            animation-delay: 0.4s;
        }
</style>