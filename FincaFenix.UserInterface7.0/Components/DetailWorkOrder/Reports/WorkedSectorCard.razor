<div class="mx-3">
    <div class="stats-card stats-card-active @(SectorFarmDTO.Id == SectorSelectedId ? "active" : "")" @onclick="() => SetSectorSelected(SectorFarmDTO.Id)">
        <MudPaper Elevation="2" Class="stats-paper">
            <div class="stats-content">
                <div class="stats-icon-wrapper stats-icon-created">
                    <MudIcon Icon="@Icons.Material.Filled.Fullscreen" Class="stats-icon" />
                </div>
                <div class="stats-info">
                    <MudText Class="stats-title" Typo="Typo.subtitle2">Cuadro</MudText>
                    <MudText Class="stats-number stats-number-active" Typo="Typo.h4">@SectorFarmDTO.SectorName</MudText>
                    <MudText Class="trend-text" Typo="Typo.h4">@SectorFarmDTO.Area ha @SectorFarmDTO.Id</MudText>
                </div>
            </div>
            <div class="stats-trend">
                <MudIcon Icon="@Icons.Material.Filled.Info" Class="trend-icon trend-created" />
                <span class="trend-text">@SectorFarmDTO.FruitName - @SectorFarmDTO.VarietyName</span>
            </div>
        </MudPaper>
    </div>
</div>

<style>
    .stats-card {
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 16px;
        overflow: hidden;
        position: relative;
    }

    .stats-paper {
        padding: 1.5rem !important;
        border-radius: 16px !important;
        background: white !important;
        border: 1px solid rgba(0, 0, 0, 0.06) !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }

    .stats-card:hover .stats-paper {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15) !important;
    }

    .stats-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--card-gradient-start), var(--card-gradient-end));
        opacity: 0;
        transition: opacity 0.3s ease;
        z-index: 1;
    }

    .stats-card:hover::before {
        opacity: 1;
    }

    .stats-card.active::before {
        opacity: 1;
    }

    .stats-card.active .stats-paper {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15) !important;
    }

    .stats-content {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .stats-icon-wrapper {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

        .stats-icon-wrapper::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, var(--icon-bg-start), var(--icon-bg-end));
            opacity: 0.1;
        }

    .stats-icon {
        font-size: 28px !important;
        color: var(--icon-color) !important;
        z-index: 1;
        position: relative;
    }

    .stats-info {
        flex: 1;
    }

    .stats-title {
        color: #64748b !important;
        font-weight: 500 !important;
        margin-bottom: 0.25rem !important;
        font-size: 0.875rem !important;
    }

    .stats-number {
        font-weight: 700 !important;
        margin: 0 !important;
        line-height: 1.2 !important;
    }

    .stats-trend {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding-top: 0.75rem;
        border-top: 1px solid rgba(0, 0, 0, 0.06);
    }

    .trend-icon {
        font-size: 16px !important;
    }

    .trend-text {
        font-size: 0.75rem;
        color: #64748b;
        font-weight: 500;
    }

    /* Colores específicos para cada tipo de tarjeta */
    .stats-card-created {
        --card-gradient-start: #3b82f6;
        --card-gradient-end: #1d4ed8;
        --icon-bg-start: #3b82f6;
        --icon-bg-end: #1d4ed8;
        --icon-color: #3b82f6;
    }

    .stats-number-created {
        color: #3b82f6 !important;
    }

    .stats-card-active {
        --card-gradient-start: #10b981;
        --card-gradient-end: #059669;
        --icon-bg-start: #10b981;
        --icon-bg-end: #059669;
        --icon-color: #10b981;
    }

    .stats-number-active {
        color: #10b981 !important;
    }

    .stats-card-pending {
        --card-gradient-start: #f59e0b;
        --card-gradient-end: #d97706;
        --icon-bg-start: #f59e0b;
        --icon-bg-end: #d97706;
        --icon-color: #f59e0b;
    }

    .stats-number-pending {
        color: #f59e0b !important;
    }

    .stats-card-closed {
        --card-gradient-start: #ef4444;
        --card-gradient-end: #dc2626;
        --icon-bg-start: #ef4444;
        --icon-bg-end: #dc2626;
        --icon-color: #ef4444;
    }

    .stats-number-closed {
        color: #ef4444 !important;
    }

    .trend-created {
        color: #3b82f6 !important;
    }

    .trend-up {
        color: #10b981 !important;
    }

    .trend-down {
        color: #f59e0b !important;
    }

    .trend-completed {
        color: #ef4444 !important;
    }

    /* Responsive adjustments */
    @@media (max-width: 960px) {
        .stats-paper {
            padding: 1.25rem !important;
        }

        .stats-content {
            gap: 0.75rem;
        }

        .stats-icon-wrapper {
            width: 50px;
            height: 50px;
        }

        .stats-icon {
            font-size: 24px !important;
        }
    }

    /* Animaciones */
    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .stats-card {
        animation: slideUp 0.6s ease-out;
    }

        .stats-card:nth-child(1) {
            animation-delay: 0.1s;
        }

        .stats-card:nth-child(2) {
            animation-delay: 0.2s;
        }

        .stats-card:nth-child(3) {
            animation-delay: 0.3s;
        }

        .stats-card:nth-child(4) {
            animation-delay: 0.4s;
        }
</style>