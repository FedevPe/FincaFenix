@code {
    [Parameter] public IEnumerable<DetailRecipeDTO> DetailRecipeList { get; set; }

    private decimal CalculatePercentagePerformance(DetailRecipeDTO producto)
    {
        if (producto.EstimatedAmount == 0) return 0;

        // Forzar conversión explícita para evitar problemas de precisión
        var consumed = Convert.ToDecimal(producto.TotalAmountConsumed);
        var estimated = Convert.ToDecimal(producto.EstimatedAmount);

        var result = (consumed / estimated) * 100m;

        // Log adicional para debug
        Console.WriteLine($"Producto: {producto.Material?.ArticleName} | Consumido: {consumed} | Estimado: {estimated} | Resultado: {result}");

        return result;
    }
}

<style>
    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
    }

    .product-card {
        background: #fafbfb;
        border: 1px solid #e8ecec;
        border-radius: 8px;
        padding: 20px;
        position: relative;
        overflow: hidden;
    }

    .product-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
    }

    .product-name {
        color: #2d5a5a;
        font-size: 14px;
        font-weight: 500;
        flex: 1;
        margin-right: 12px;
    }

    .product-brand {
        background: #e8f4f2;
        color: #4a9b8e;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 500;
    }

    .progress-section {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 20px 0;
        flex-direction: column;
    }

    .consumption-value {
        font-size: 16px;
        font-weight: 600;
        color: #2d5a5a;
        display: block;
    }

    .consumption-details {
        display: flex;
        justify-content: space-between;
        margin-top: 16px;
        font-size: 12px;
        flex-wrap: wrap;
        gap: 8px;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
        min-width: 80px;
    }

    .detail-label {
        color: #6b7d7d;
        margin-bottom: 4px;
        font-size: 11px;
    }

    .detail-value {
        color: #2d5a5a;
        font-weight: 500;
    }

    .detail-teorico {
        color: #4a9b8e;
    }

    .detail-exceso {
        color: #e74c3c;
    }

    .linear-progress {
        width: 100%;
        height: 8px;
        background: #e8ecec;
        border-radius: 4px;
        overflow: visible;
        margin: 16px 0;
        position: relative;
    }

    .linear-progress-bar {
        height: 100%;
        background: linear-gradient(90deg, #4a9b8e 0%, #6bb6a8 100%);
        border-radius: 4px;
        transition: width 0.8s ease;
        max-width: 100%;
    }

    .linear-progress-excess {
        height: 100%;
        background: linear-gradient(90deg, #e74c3c 0%, #ec7063 100%);
        border-radius: 4px;
        transition: width 0.8s ease;
        position: absolute;
        top: 0;
        left: 100%;
        max-width: 100%;
    }
</style>


