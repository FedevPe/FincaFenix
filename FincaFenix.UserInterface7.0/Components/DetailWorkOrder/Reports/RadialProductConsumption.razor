<MudGrid Justify="Justify.FlexStart">
    <MudItem lg="12" xs="12">
        <div class="consumption-card">
            <div class="consumption-header">
                <div class="consumption-value">
                    @_totalPerformance.ToString("N2") lts
                    <span class="consumption-estimate">
                        de @_totalApplicationForSector.ToString("N2") lts estimados
                    </span>
                </div>
                <div class="consumption-percentage @(_porcentaje > 100 ? "excess" : "normal")">
                    @_porcentaje.ToString("N1")%
                </div>
            </div>

            <div class="progress-container">
                <div class="progress-track">
                    @if (_widthExceso > 0)
                    {
                        <MudProgressLinear Rounded="true" Color="Color.Error" Value="@Math.Min(_widthExceso, 100)" Size="Size.Large" />
                        @if (_widthExceso > 100)
                        {
                            <MudProgressLinear Rounded="true" Color="Color.Warning" Value="@_widthExceso" Size="Size.Large" />
                        }
                    }
                    else
                    {
                        <MudProgressLinear Rounded="true" Color="Color.Secondary" Value="@_widthNormal" Size="Size.Large" />

                    }
                </div>

                <div class="progress-markers">
                    <div class="marker start">0</div>
                    <div class="marker end">@_totalApplicationForSector.ToString("N0") lts</div>
                </div>
            </div>

            <div class="consumption-status">
                <span class="status-indicator @(_porcentaje > 100 ? "warning" : "success")"></span>
                <span class="status-text">
                    @(_porcentaje > 100 ? "Consumo excedido" : "Dentro del límite")
                </span>
            </div>
        </div>
    </MudItem>
    <MudItem lg="12" xs="12">
        @if (_calculatedRecipe.Details != null)
        {
            <MudGrid Justify="Justify.FlexStart">
                @foreach (var product in _calculatedRecipe.Details)
                {
                    <MudItem lg="6" xs="6">
                        <div class="product-card">
                            <div class="product-header">
                                <div class="product-name">@product.Material.ArticleName</div>
                                <div class="product-brand">@product.Brand.ToUpper()</div>
                            </div>
                            <div class="consumption-details">
                                <div class="detail-item">
                                    <span class="detail-label">Consumo estimado</span>
                                    <span class="detail-value estimated">@product.EstimatedAmount.ToString("N2") @product.EstimatedAmountUnit</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Cantidad consumida</span>
                                    <span class="detail-value consumed">@product.TotalAmountConsumed.ToString("F2") @product.EstimatedAmountUnit</span>
                                </div>
                                @if (product.TotalAmountConsumed > product.EstimatedAmount)
                                {
                                    <div class="detail-item excess-item">
                                        <span class="detail-label">Exceso</span>
                                        <span class="detail-value detail-exceso">
                                            <span class="excess-indicator"></span>
                                            @((product.TotalAmountConsumed - product.EstimatedAmount).ToString("F2")) @product.EstimatedAmountUnit
                                        </span>
                                    </div>
                                }
                                else
                                {
                                    <div class="detail-item normal-item">
                                        <span class="detail-label">Diferencia</span>
                                        <span class="detail-value detail-teorico">
                                            <span class="normal-indicator"></span>
                                            @((product.EstimatedAmount - product.TotalAmountConsumed).ToString("F2")) @product.EstimatedAmountUnit
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudItem>
</MudGrid>
@code {
    [Inject] private CalculateMaterialConsumedViewModel ViewModel { get; set; }

    [Parameter] public IEnumerable<DetailRecipeDTO> DetailRecipeList { get; set; }
    [Parameter] public RecipeWorkOrderDTO Recipe { get; set; }
    [Parameter] public IEnumerable<DetailWorkOrderDTO> DetailWorkOrderList { get; set; }
    [Parameter] public decimal TotalAreaWorkedForSector { get; set; }
    [Parameter] public decimal TotalApplicationForSector { get; set; }

    private decimal _totalPerformance;
    private decimal _totalApplicationForSector;
    private RecipeWorkOrderDTO _calculatedRecipe; // Almacenará la receta con los valores calculados
    private double _widthNormal;
    private double _widthExceso;
    private decimal _porcentaje;

    protected override async Task OnInitializedAsync()
    {
        _calculatedRecipe = await ViewModel.CalculateEstimatedAndConsumedAmounts(
             Recipe,
             DetailWorkOrderList,
             TotalAreaWorkedForSector
         );
        _totalPerformance = ViewModel.TotalPerfomance;
        _totalApplicationForSector = TotalApplicationForSector;
        RenderProgressoLineal();
    }

    private void RenderProgressoLineal()
    {
        _porcentaje = (_totalPerformance / TotalApplicationForSector) * 100;
        _widthNormal = (double)(Math.Min(_porcentaje, 100));
        _widthExceso = (double)(_porcentaje > 100 ? _porcentaje - 100 : 0);
    }
}

