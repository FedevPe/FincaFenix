<div class="products-grid my-5">
    @if (DetailRecipeList != null)
    {
        @foreach (var product in DetailRecipeList)
        {
            <div class="product-card mud-elevation-3">
                <div class="product-header">
                    <div class="product-name">@product.Material.ArticleName</div>
                    <div class="product-brand">@product.Brand.ToUpper()</div>
                </div>
                <div class="consumption-details">
                    <div class="detail-item">
                        <span class="detail-label">Cant. consumida</span>
                        <span class="detail-value">@product.TotalAmountConsumed.ToString("F2") @product.EstimatedAmountUnit</span>                        
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Consumo estimado</span>
                        <span class="detail-value">@product.EstimatedAmount.ToString("N2") @product.EstimatedAmountUnit</span>
                    </div>                
                </div>
            </div>
        }
    }
</div>
<div class="mud-elevation-3">

</div>
