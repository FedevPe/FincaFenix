<div class="d-flex justify-content-start align-items-center w-100">
    @foreach (var sector in SectorList)
    {
        <WorkedSectorCard SectorFarmDTO="@sector" OnSectorSelectedChanged="HandleSectorSelected" SectorSelectedId="@sectorSelectedId" />
    }
</div>
<div>
    <div class="container-fluid">
        @if (sectorSelectedId != 0)
        {
            @if (_detailWorkOrderFilteredList.Any() && _recipe != null)
            {
                <div class="my-3">
                    <RadialProductConsumption @key="sectorSelectedId"
                                       DetailWorkOrderList="_detailWorkOrderFilteredList"
                                       Recipe="_recipe"
                                       TotalAreaWorkedForSector="SectorSelected.Area.Value"
                                       TotalApplicationForSector="_totalApplicationForSector"/>
                </div>
            }
            else if ((_detailWorkOrderFilteredList.Any() && _recipe == null))
            {
                <div class="empty-state-card">
                    <div class="empty-state-content">
                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="empty-state-icon" />
                        <MudText Typo="Typo.h6" Class="empty-state-title">Cuadro sin actividades registradas.</MudText>
                        <MudText Typo="Typo.body1" Class="empty-state-description">
                            Aún no se pueden mostrar los datos relacionados. Porque no se han registrados actividades en el cuadro seleccionado.
                        </MudText>
                    </div>
                </div>
            }
            else
            {
                <div class="empty-state-card">
                    <div class="empty-state-content">
                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="empty-state-icon" />
                        <MudText Typo="Typo.h6" Class="empty-state-title">Cuadro sin actividades registradas.</MudText>
                        <MudText Typo="Typo.body1" Class="empty-state-description">
                            Aún no se pueden mostrar los datos relacionados. Porque no se han registrados actividades en el cuadro seleccionado.
                        </MudText>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state-card">
                <div class="empty-state-content">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="empty-state-icon" />
                    <MudText Typo="Typo.h6" Class="empty-state-title">Debe seleccionar un cuadro de trabajo.</MudText>
                    <MudText Typo="Typo.body1" Class="empty-state-description">
                        Aún no se pueden mostrar los datos relacionados. No se ha seleccionado el cuadro de trabajo.
                    </MudText>
                </div>
            </div>
        }
    </div>
    <div>

    </div>
</div>
@code {
    [Parameter] public IEnumerable<DetailSectorFarmDTO> SectorList { get; set; }
    [Parameter] public IEnumerable<DetailWorkOrderDTO> DetailWorkOrderDTO { get; set; }
    [Parameter] public RecipeWorkOrderDTO Recipe { get; set; }

    private int sectorSelectedId = 0;
    private DetailSectorFarmDTO SectorSelected;
    private List<DetailWorkOrderDTO> _detailWorkOrderFilteredList;
    private RecipeWorkOrderDTO _recipe;
    private decimal _totalApplicationForSector;
    private decimal _totalApplicationAllSector;
    private decimal _totalAreaWorkedAllSector;

    protected override void OnInitialized()
    {
        // Inicializa _sortedSectorList para evitar múltiples ordenamientos.
        _recipe = Recipe;
        SectorList = SectorList.OrderBy(s => s.FruitName);
        _totalAreaWorkedAllSector = SectorList.Sum(x => x.Area.Value);
        _totalApplicationAllSector = SectorList.Sum(x => x.Area.Value) * _recipe.TRV;
    }

    private void HandleSectorSelected(int id)
    {
        sectorSelectedId = id;
        _totalApplicationForSector = SectorList.Sum(x => x.Area.Value) * _recipe.TRV;
        // Aplica la lógica de filtrado en el componente padre.
        if (sectorSelectedId != 0)
        {
            _detailWorkOrderFilteredList = DetailWorkOrderDTO.Where(ds => ds.Sector.Id == id).ToList();
            SectorSelected = SectorList.FirstOrDefault(ds => ds.Id == id);
            _totalApplicationForSector = (SectorSelected.Area.Value * _totalApplicationAllSector) / _totalAreaWorkedAllSector;
        }
        StateHasChanged();
    }
}
<style>
    .empty-state-card {
        background: #f8fafc;
        border-radius: 16px;
        padding: 3rem 2rem;
        border: 1px solid #e2e8f0;
        margin: 1rem 0;
    }

    .empty-state-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 1rem;
    }

    .empty-state-icon {
        font-size: 48px !important;
        color: #94a3b8;
        opacity: 0.7;
    }

    .empty-state-title {
        color: #475569 !important;
        font-weight: 600 !important;
        margin: 0 !important;
    }

    .empty-state-description {
        color: #64748b !important;
        max-width: 400px !important;
        line-height: 1.6 !important;
        margin: 0 !important;
    }
</style>

