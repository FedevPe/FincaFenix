<div class="recipe-toolbar-content">
    <MudChip T="string" Class="recipe-toolbar-chip" Label="true" Icon="@Icons.Material.Filled.Build" Size="Size.Medium">Maquina: @Recipe.Machine.Name</MudChip>
    <MudChip T="string" Class="recipe-toolbar-chip" Label="true" Icon="@Icons.Material.Filled.WaterDrop" Size="Size.Medium">Capacidad: @Recipe.VolumeMachine.ToString("N2") @Recipe.VolumeMachineUnit</MudChip>
    <MudChip T="string" Class="recipe-toolbar-chip" Label="true" Icon="@Icons.Material.Filled.Speed" Size="Size.Medium">TRV: @Recipe.TRV.ToString("N2") lts/ha</MudChip>
    <MudChip T="string" Class="recipe-toolbar-chip" Label="true" Icon="@Icons.Material.Filled.Straighten" Size="Size.Medium">Hectareas: @TotalAreaWorked.ToString("N2") ha</MudChip>
    <MudChip T="string" Class="recipe-toolbar-chip" Label="true" Icon="@Icons.Material.Filled.Calculate" Size="Size.Medium">Maquinadas: @_machineAplications.ToString("N2")</MudChip>
</div>
<div class="recipe-table-wrapper">
    <MudTable T="DetailRecipeDTO"
              Items="@Recipe.Details"
              Dense="true"
              Hover="true"
              Bordered="true"
              Class="recipe-mud-table"
              Elevation="0"
              Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh Class="recipe-table-header">
                <MudTableSortLabel SortBy="new Func<DetailRecipeDTO, object>(x => x.Material.ArticleName)">
                    <div class="recipe-header-content">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory" Class="recipe-header-icon" />
                        <span>Producto</span>
                    </div>
                </MudTableSortLabel>
            </MudTh>
            <MudTh Class="recipe-table-header">
                <MudTableSortLabel SortBy="new Func<DetailRecipeDTO, object>(x => x.Material.Brand)">
                    <div class="recipe-header-content">
                        <MudIcon Icon="@Icons.Material.Filled.Circle" Class="recipe-header-icon" />
                        <span>Marca</span>
                    </div>
                </MudTableSortLabel>
            </MudTh>
            <MudTh Class="recipe-table-header">
                <MudTableSortLabel SortBy="new Func<DetailRecipeDTO, object>(x => x.Material.Category.Description)">
                    <div class="recipe-header-content">
                        <MudIcon Icon="@Icons.Material.Filled.Category" Class="recipe-header-icon" />
                        <span>Categoría</span>
                    </div>
                </MudTableSortLabel>
            </MudTh>
            <MudTh Class="recipe-table-header">
                <MudTableSortLabel SortBy="new Func<DetailRecipeDTO, object>(x => x.Material.DiseasePlague)">
                    <div class="recipe-header-content">
                        <MudIcon Icon="@Icons.Material.Filled.BugReport" Class="recipe-header-icon" />
                        <span>Plaga/Enfermedad</span>
                    </div>
                </MudTableSortLabel>
            </MudTh>
            <MudTh Class="recipe-table-header">
                <MudTableSortLabel SortBy="new Func<DetailRecipeDTO, object>(x => x.AmountRequired)">
                    <div class="recipe-header-content">
                        <MudIcon Icon="@Icons.Material.Filled.Science" Class="recipe-header-icon" />
                        <span>Dosis</span>
                    </div>
                </MudTableSortLabel>
            </MudTh>
            <MudTh Class="recipe-table-header">
                <MudTableSortLabel SortBy="new Func<DetailRecipeDTO, object>(x => x.EstimatedAmount)">
                    <div class="recipe-header-content">
                        <MudIcon Icon="@Icons.Material.Filled.Calculate" Class="recipe-header-icon" />
                        <span>Cant. Estimada</span>
                    </div>
                </MudTableSortLabel>
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Producto" Class="recipe-table-cell">
                <div class="recipe-cell-content recipe-product-content">
                    <MudIcon Icon="@Icons.Material.Filled.CheckBox" Class="recipe-cell-icon recipe-estimate-icon" />
                    <MudTooltip Text="@context.Material.ArticleName">
                        <span class="recipe-product-name">@context.Material.ArticleName</span>
                    </MudTooltip>
                </div>
            </MudTd>
            <MudTd DataLabel="Marca" Class="recipe-table-cell">
                <div class="recipe-cell-content">
                    @if (!string.IsNullOrEmpty(context.Brand))
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Class="recipe-brand-chip">
                            @context.Brand
                        </MudChip>
                    }
                    else
                    {
                        <span class="recipe-no-pest">Sin marca</span>
                    }
                </div>
            </MudTd>
            <MudTd DataLabel="Categoría" Class="recipe-table-cell">
                <div class="recipe-cell-content">
                    <MudIcon Icon="@Icons.Material.Filled.Science" Class="recipe-cell-icon recipe-estimate-icon" />
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                             Color="@Color.Secondary"
                             Class="recipe-category-chip">
                        @context.Material.Category.Description
                    </MudChip>
                </div>
            </MudTd>
            <MudTd DataLabel="Plaga/Enfermedad" Class="recipe-table-cell">
                <div class="recipe-cell-content recipe-pest-content">
                    @if (!string.IsNullOrEmpty(context.PestDisease))
                    {
                        <MudChip T="string" Class="recipe-estimate-chip">
                            @context.PestDisease
                        </MudChip>
                    }
                    else
                    {
                        <span class="recipe-no-pest">Sin registro</span>
                    }
                </div>
            </MudTd>
            <MudTd DataLabel="Dosis" Class="recipe-table-cell">
                <div class="recipe-cell-content recipe-dose-content">
                    <MudIcon Icon="@Icons.Material.Filled.Scale" Class="recipe-cell-icon recipe-estimate-icon" />
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Secondary" Class="recipe-dose-chip">
                        @context.AmountRequired @context.AmountRequiredUnit
                    </MudChip>
                </div>
            </MudTd>
            <MudTd DataLabel="Cant. Estimada" Class="recipe-table-cell">
                <div class="recipe-cell-content">
                    <MudIcon Icon="@Icons.Material.Filled.Functions" Class="recipe-cell-icon recipe-estimate-icon" />
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="recipe-estimate-chip">
                        @context.EstimatedAmount @context.EstimatedAmountUnit
                    </MudChip>
                </div>
            </MudTd>
        </RowTemplate>
    </MudTable>
</div>

<style>
    .recipe-table-wrapper {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        margin: 1.5rem 0;
        border: 1px solid rgba(0, 0, 0, 0.06);
    }

    .recipe-mud-table {
        background: transparent !important;
    }

    /* Recipe Toolbar Styles */
    .recipe-toolbar-content {
        display: flex;
        align-items: center;
        justify-content: space-evenly;
        width: 100%;
        background: #ffffff;
    }
    .recipe-toolbar-chip{
        background: #004d40;
        color: white;
    }
    .recipe-toolbar-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .recipe-toolbar-icon {
        color: #00796B;
        font-size: 24px !important;
    }

    .recipe-toolbar-text {
        color: #1f2937 !important;
        font-weight: 600 !important;
        margin: 0 !important;
    }

    .recipe-summary {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .recipe-summary-chip {
        background: rgba(33, 150, 243, 0.1) !important;
        color: white !important;
        font-weight: 500;
    }

    /* Recipe Header Styles */
    .recipe-table-header {
        background: #00796B !important;
        color: white !important;
        font-weight: 600 !important;
        padding: 1rem 1.25rem !important;
        border: none !important;
        position: relative;
    }

        .recipe-table-header::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, rgba(255,255,255,0.3), rgba(255,255,255,0.1), rgba(255,255,255,0.3));
        }

    .recipe-header-content {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: white;
    }

    .recipe-header-icon {
        font-size: 18px !important;
        opacity: 0.9;
    }

    /* Recipe Cell Styles */
    .recipe-table-cell {
        padding: 1rem 1.25rem !important;
        border-bottom: 1px solid rgba(0, 0, 0, 0.06) !important;
        vertical-align: middle !important;
        background: white;
        transition: background-color 0.2s ease;
    }

    .recipe-mud-table tbody tr:hover .recipe-table-cell {
        background: #f8fafb !important;
    }

    .recipe-cell-content {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .recipe-cell-icon {
        font-size: 16px !important;
        color: white;
        opacity: 0.7;
    }

    /* Recipe Product Content */
    .recipe-product-content {
        max-width: 200px;
    }

    .recipe-product-name {
        font-weight: 600;
        font-family: monospace;
        min-width: 60px;
        text-align: center;
    }

    /* Recipe Brand Styles */
    .recipe-brand-chip {
        font-weight: 600;
        font-family: monospace;
        min-width: 60px;
        text-align: center;
    }

    .recipe-no-brand {
        color: #2F2F2E;
        font-style: italic;
        font-size: 0.875rem;
    }

    /* Recipe Category Styles */
    .recipe-category-icon {
        color: #F0F0ED !important;
    }

    .recipe-category-chip {
        font-weight: 600;
        font-family: monospace;
        min-width: 60px;
        text-align: center;
    }

    /* Recipe Pest/Disease Content */
    .recipe-pest-name {
        font-weight: 600;
        font-family: monospace;
        min-width: 60px;
        text-align: center;
    }

    .recipe-no-pest {
        color: #2F2F2E;
        font-weight: 500;
        font-size: 0.875rem;
    }

    /* Recipe Dose Styles */
    .recipe-dose-content {
        justify-content: flex-start;
    }

    .recipe-dose-chip {
        font-weight: 600;
        font-family: monospace;
        min-width: 60px;
        text-align: center;
    }

    .recipe-estimate-icon {
        color: #2F2F2E;
        font-weight: 500;
        font-size: 0.875rem;
    }

    .recipe-estimate-chip {
        font-weight: 600;
        font-family: monospace;
        min-width: 60px;
        text-align: center;
    }

    /* Recipe Responsive Design */
    @@media (max-width: 768px) {
        .recipe-table-wrapper

    {
        border-radius: 12px;
        margin: 1rem 0;
    }

    .recipe-toolbar-content {
        flex-direction: column;
        gap: 1rem;
        padding: 1rem;
    }

    .recipe-table-header,
    .recipe-table-cell {
        padding: 0.75rem 1rem !important;
    }

    .recipe-header-content {
        flex-direction: column;
        gap: 0.25rem;
        text-align: center;
    }

    .recipe-header-icon {
        font-size: 16px !important;
    }

    .recipe-product-name,
    .recipe-pest-name {
        max-width: 120px;
    }

    }

    @@media (max-width: 480px) {
        .recipe-toolbar-content

    {
        padding: 0.75rem;
    }

    .recipe-toolbar-title {
        flex-direction: column;
        gap: 0.5rem;
        text-align: center;
    }

    .recipe-cell-content {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.25rem;
    }

    .recipe-dose-chip,
    .recipe-estimate-chip {
        min-width: 70px;
    }

    }

    /* Recipe Animations */
    @@keyframes recipeTableFadeInUp {
        from

    {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .recipe-mud-table tbody tr {
        animation: recipeTableFadeInUp 0.3s ease-out;
    }

        .recipe-mud-table tbody tr:nth-child(odd) {
            animation-delay: 0.05s;
        }

        .recipe-mud-table tbody tr:nth-child(even) {
            animation-delay: 0.1s;
        }

    /* Recipe Category Colors */
    .recipe-mud-table .mud-chip.mud-chip-color-success {
        background: linear-gradient(135deg, #10b981, #059669) !important;
    }

    .recipe-mud-table .mud-chip.mud-chip-color-warning {
        background: linear-gradient(135deg, #f59e0b, #d97706) !important;
    }

    .recipe-mud-table .mud-chip.mud-chip-color-error {
        background: linear-gradient(135deg, #ef4444, #dc2626) !important;
    }

    .recipe-mud-table .mud-chip.mud-chip-color-info {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8) !important;
    }
</style>

@code {
    private decimal _machineAplications;
    [Parameter] public RecipeWorkOrderDTO Recipe { get; set; }
    [Parameter] public decimal TotalAreaWorked { get; set; }

    protected override void OnInitialized()
    {
        _machineAplications = ((TotalAreaWorked * Recipe.TRV) / Recipe.VolumeMachine);
    }
}