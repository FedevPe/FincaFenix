<div class="recipe-toolbar-content">
    <div class="recipe-toolbar-chips">
        <MudChip T="string"
                 Class="recipe-toolbar-chip"
                 Label="true"
                 Icon="@Icons.Material.Filled.Numbers"
                 Size="Size.Medium">
            Receta N° #@Recipe.NumRecipe
        </MudChip>
        <MudChip T="string"
                 Class="recipe-toolbar-chip"
                 Label="true"
                 Icon="@Icons.Material.Filled.Build"
                 Size="Size.Medium">
            Maquina: @Recipe.Machine.Name
        </MudChip>
        <MudChip T="string"
                 Class="recipe-toolbar-chip"
                 Label="true"
                 Icon="@Icons.Material.Filled.WaterDrop"
                 Size="Size.Medium">
            Capacidad: @Recipe.VolumeMachine.ToString("N2") @Recipe.VolumeMachineUnit
        </MudChip>
        <MudChip T="string"
                 Class="recipe-toolbar-chip"
                 Label="true"
                 Icon="@Icons.Material.Filled.Speed"
                 Size="Size.Medium">
            TRV: @Recipe.TRV.ToString("N2") lts/ha
        </MudChip>
        <MudChip T="string"
                 Class="recipe-toolbar-chip"
                 Label="true"
                 Icon="@Icons.Material.Filled.Straighten"
                 Size="Size.Medium">
            Hectareas: @TotalAreaWorked.ToString("N2") ha
        </MudChip>
        <MudChip T="string"
                 Class="recipe-toolbar-chip"
                 Label="true"
                 Icon="@Icons.Material.Filled.Calculate"
                 Size="Size.Medium">
            Maquinadas: @_machineAplications.ToString("N2")
        </MudChip>
    </div>
</div>
<div class="recipe-table-wrapper">
    <MudTable T="DetailRecipeDTO"
              Items="@Recipe.Details"
              Dense="true"
              Hover="true"
              Bordered="true"
              Class="recipe-mud-table"
              Elevation="3"
              Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh Class="recipe-table-header">
                <MudTableSortLabel SortBy="new Func<DetailRecipeDTO, object>(x => x.Material.ArticleName)">
                    <div class="recipe-header-content">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory" Class="recipe-header-icon" />
                        <span>Producto</span>
                    </div>
                </MudTableSortLabel>
            </MudTh>
            <MudTh Class="recipe-table-header">
                <MudTableSortLabel SortBy="new Func<DetailRecipeDTO, object>(x => x.Material.Brand)">
                    <div class="recipe-header-content">
                        <MudIcon Icon="@Icons.Material.Filled.Circle" Class="recipe-header-icon" />
                        <span>Marca</span>
                    </div>
                </MudTableSortLabel>
            </MudTh>
            <MudTh Class="recipe-table-header">
                <MudTableSortLabel SortBy="new Func<DetailRecipeDTO, object>(x => x.Material.Category.Description)">
                    <div class="recipe-header-content">
                        <MudIcon Icon="@Icons.Material.Filled.Category" Class="recipe-header-icon" />
                        <span>Categoría</span>
                    </div>
                </MudTableSortLabel>
            </MudTh>
            <MudTh Class="recipe-table-header">
                <MudTableSortLabel SortBy="new Func<DetailRecipeDTO, object>(x => x.Material.DiseasePlague)">
                    <div class="recipe-header-content">
                        <MudIcon Icon="@Icons.Material.Filled.BugReport" Class="recipe-header-icon" />
                        <span>Plaga/Enfermedad</span>
                    </div>
                </MudTableSortLabel>
            </MudTh>
            <MudTh Class="recipe-table-header">
                <MudTableSortLabel SortBy="new Func<DetailRecipeDTO, object>(x => x.AmountRequired)">
                    <div class="recipe-header-content">
                        <MudIcon Icon="@Icons.Material.Filled.Science" Class="recipe-header-icon" />
                        <span>Dosis</span>
                    </div>
                </MudTableSortLabel>
            </MudTh>
            <MudTh Class="recipe-table-header">
                <MudTableSortLabel SortBy="new Func<DetailRecipeDTO, object>(x => x.EstimatedAmount)">
                    <div class="recipe-header-content">
                        <MudIcon Icon="@Icons.Material.Filled.Calculate" Class="recipe-header-icon" />
                        <span>Cant. Estimada</span>
                    </div>
                </MudTableSortLabel>
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Producto" Class="recipe-table-cell">
                <div class="recipe-cell-content recipe-product-content">                    
                    <MudTooltip Text="@context.Material.ArticleName">
                        <span>@context.Material.ArticleName</span>
                    </MudTooltip>
                </div>
            </MudTd>
            <MudTd DataLabel="Marca" Class="recipe-table-cell">
                <div class="recipe-cell-content">
                    @if (!string.IsNullOrEmpty(context.Brand))
                    {
                        <span>@context.Brand</span>
                    }
                    else
                    {
                        <span>Sin marca</span>
                    }
                </div>
            </MudTd>
            <MudTd DataLabel="Categoría" Class="recipe-table-cell">
                <div class="recipe-cell-content">                    
                    <span>
                        @context.Material.Category.Description.ToUpper()
                    </span>
                </div>
            </MudTd>
            <MudTd DataLabel="Plaga/Enfermedad" Class="recipe-table-cell">
                <div class="recipe-cell-content recipe-pest-content">
                    @if (!string.IsNullOrEmpty(context.PestDisease))
                    {
                        <span>
                            @context.PestDisease
                        </span>
                    }
                    else
                    {
                        <span>Sin registro</span>
                    }
                </div>
            </MudTd>
            <MudTd DataLabel="Dosis" Class="recipe-table-cell">
                <div class="recipe-cell-content recipe-dose-content">                    
                    <span >
                        @context.AmountRequired.ToString("N2") @context.AmountRequiredUnit
                    </span>
                </div>
            </MudTd>
            <MudTd DataLabel="Cant. Estimada" Class="recipe-table-cell">
                <div class="recipe-cell-content">                    
                    <span>
                        @context.EstimatedAmount.ToString("N2") @context.EstimatedAmountUnit
                    </span>
                </div>
            </MudTd>
        </RowTemplate>
    </MudTable>
</div>

<style>
    .recipe-table-wrapper {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        margin: 1.5rem 0;
        border: 1px solid rgba(0, 0, 0, 0.06);
    }

    .recipe-mud-table {
        background: transparent !important;
    }

    .recipe-toolbar-content {
        width: 100%;
        background: white;
        border-radius: 12px;
        padding: 16px 20px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .recipe-toolbar-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
        justify-content: center;
    }

    .recipe-toolbar-chip {
        background: #f8fafb !important;
        border: 1px solid rgba(0, 0, 0, 0.08) !important;
        border-radius: 20px !important;
        padding: 8px 16px !important;
        font-size: 14px !important;
        font-weight: 500 !important;
        color: #374151 !important;
        transition: all 0.2s ease !important;
        white-space: nowrap !important;
        min-height: 36px !important;
        flex-shrink: 0 !important;
        height: auto !important;
    }

        .recipe-toolbar-chip:hover {
            background: #f1f5f9 !important;
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1) !important;
        }

        .recipe-toolbar-chip .mud-icon {
            font-size: 18px !important;
            width: 18px !important;
            height: 18px !important;
            margin-right: 8px !important;
        }

    /* Responsive Design */
    @@media (max-width: 1200px) {
        .recipe-toolbar-chips

    {
        gap: 10px;
    }

    .recipe-toolbar-chip {
        padding: 7px 14px !important;
        font-size: 13px !important;
    }

    }

    @@media (max-width: 768px) {
        .recipe-toolbar-content

    {
        padding: 12px 16px;
    }

    .recipe-toolbar-chips {
        gap: 8px;
        justify-content: center;
    }

    .recipe-toolbar-chip {
        padding: 6px 12px !important;
        font-size: 12px !important;
        min-height: 32px !important;
    }

        .recipe-toolbar-chip .mud-icon {
            font-size: 16px !important;
            width: 16px !important;
            height: 16px !important;
        }

    }

    @@media (max-width: 480px) {
        .recipe-toolbar-chips

    {
        flex-direction: column;
        align-items: stretch;
        gap: 6px;
    }

    .recipe-toolbar-chip {
        justify-content: center;
        flex-shrink: 1 !important;
        min-width: 0;
        text-align: center;
    }

    }

    /* Recipe Header Styles */
    .recipe-table-header {
        background: #00796B !important;
        color: white !important;
        font-weight: 600 !important;
        padding: 1rem 1.25rem !important;
        border: none !important;
        position: relative;
    }

        .recipe-table-header::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, rgba(255,255,255,0.3), rgba(255,255,255,0.1), rgba(255,255,255,0.3));
        }

    .recipe-header-content {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: white;
    }

    .recipe-header-icon {
        font-size: 18px !important;
        opacity: 0.9;
    }

    /* Recipe Cell Styles */
    .recipe-table-cell {
        padding: 1rem 1.25rem !important;
        border-bottom: 1px solid rgba(0, 0, 0, 0.06) !important;
        vertical-align: middle !important;
        background: white;
        transition: background-color 0.2s ease;
    }

    .recipe-mud-table tbody tr:hover .recipe-table-cell {
        background: #f8fafb !important;
    }

    .recipe-cell-content {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .recipe-cell-icon {
        font-size: 16px !important;
        color: white;
        opacity: 0.7;
    }

    /* Recipe Product Content */
    .recipe-product-content {
        max-width: 200px;
    }

    .recipe-product-name {
        font-weight: 600;
        font-family: monospace;
        min-width: 60px;
        text-align: center;
    }

    /* Recipe Brand Styles */
    .recipe-brand-chip {
        font-weight: 600;
        font-family: monospace;
        min-width: 60px;
        text-align: center;
    }

    .recipe-no-brand {
        color: #2F2F2E;
        font-style: italic;
        font-size: 0.875rem;
    }

    /* Recipe Category Styles */
    .recipe-category-icon {
        color: #F0F0ED !important;
    }

    .recipe-category-chip {
        font-weight: 600;
        font-family: monospace;
        min-width: 60px;
        text-align: center;
    }

    /* Recipe Pest/Disease Content */
    .recipe-pest-name {
        font-weight: 600;
        font-family: monospace;
        min-width: 60px;
        text-align: center;
    }

    .recipe-no-pest {
        color: #2F2F2E;
        font-weight: 500;
        font-size: 0.875rem;
    }

    /* Recipe Dose Styles */
    .recipe-dose-content {
        justify-content: flex-start;
    }

    .recipe-dose-chip {
        font-weight: 600;
        font-family: monospace;
        min-width: 60px;
        text-align: center;
    }

    .recipe-estimate-icon {
        color: #2F2F2E;
        font-weight: 500;
        font-size: 0.875rem;
    }

    .recipe-estimate-chip {
        font-weight: 600;
        font-family: monospace;
        min-width: 60px;
        text-align: center;
    }

    /* Recipe Responsive Design */
    @@media (max-width: 768px) {
        .recipe-table-wrapper

    {
        border-radius: 12px;
        margin: 1rem 0;
    }

    .recipe-toolbar-content {
        border-radius: 12px;
        margin: 1rem 0;
        padding: 1rem;
    }

    .recipe-toolbar-header {
        margin-bottom: 1rem;
        padding: 0.75rem 1rem;
    }

    .recipe-toolbar-chips {
        flex-direction: column;
        gap: 0.75rem;
    }

    .recipe-toolbar-chip {
        width: 100%;
        justify-content: center;
    }

    .recipe-table-header,
    .recipe-table-cell {
        padding: 0.75rem 1rem !important;
    }

    .recipe-header-content {
        flex-direction: column;
        gap: 0.25rem;
        text-align: center;
    }

    .recipe-header-icon {
        font-size: 16px !important;
    }

    .recipe-product-name,
    .recipe-pest-name {
        max-width: 120px;
    }

    }

    @@media (max-width: 480px) {
        .recipe-toolbar-content

    {
        padding: 0.75rem;
    }

    .recipe-toolbar-title {
        flex-direction: column;
        gap: 0.5rem;
        text-align: center;
    }

    .recipe-toolbar-text {
        font-size: 1.1rem !important;
    }

    .recipe-cell-content {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.25rem;
    }

    .recipe-dose-chip,
    .recipe-estimate-chip {
        min-width: 70px;
    }

    }

    /* Recipe Animations */
    @@keyframes recipeTableFadeInUp {
        from

    {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .recipe-mud-table tbody tr {
        animation: recipeTableFadeInUp 0.3s ease-out;
    }

        .recipe-mud-table tbody tr:nth-child(odd) {
            animation-delay: 0.05s;
        }

        .recipe-mud-table tbody tr:nth-child(even) {
            animation-delay: 0.1s;
        }

    /* Recipe Category Colors */
    .recipe-mud-table .mud-chip.mud-chip-color-success {
        background: linear-gradient(135deg, #10b981, #059669) !important;
    }

    .recipe-mud-table .mud-chip.mud-chip-color-warning {
        background: linear-gradient(135deg, #f59e0b, #d97706) !important;
    }

    .recipe-mud-table .mud-chip.mud-chip-color-error {
        background: linear-gradient(135deg, #ef4444, #dc2626) !important;
    }

    .recipe-mud-table .mud-chip.mud-chip-color-info {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8) !important;
    }
</style>

@code {
    private decimal _machineAplications;
    [Parameter] public RecipeWorkOrderDTO Recipe { get; set; }
    [Parameter] public decimal TotalAreaWorked { get; set; }

    protected override void OnInitialized()
    {
        _machineAplications = ((TotalAreaWorked * Recipe.TRV) / Recipe.VolumeMachine);
    }
}