<div class="custom-dialog">
    <MudDialog Class="custom-dialog">
        <DialogContent>
            @* <div class="d-flex flex-column align-items-center justify-content-center py-1 w-100">
                <MudButton Variant="Variant.Filled"
                           OnClick="OnCloseClick"
                           Disabled="IsCloseDisabled()"
                           Color="Color.Error"
                           FullWidth="false"
                           Style="width: 200px"
                           Class="my-1">Cerrado</MudButton>
                <MudButton Variant="Variant.Filled"
                           OnClick="OnPendingClick"
                           Disabled="IsPendingDisabled()"
                           Color="Color.Warning"
                           FullWidth="false"
                           Style="width: 200px"
                           Class="my-1">Pendiente</MudButton>
                <MudButton Variant="Variant.Filled"
                           OnClick="OnActiveClick"
                           Disabled="IsActiveDisabled()"
                           Color="Color.Primary"
                           FullWidth="false"
                           Style="width: 200px"
                           Class="my-1">Activo</MudButton>
            </div> *@
            <div class="d-flex flex-column align-items-center justify-content-center py-1 w-100">
                @foreach (WorkOrderStateEnum state in Enum.GetValues(typeof(WorkOrderStateEnum)))
                {
                    // Convertimos el estado actual de string a enum para la comparación
                    WorkOrderStateEnum currentStatusEnum;
                    Enum.TryParse(CurrentState, out currentStatusEnum); // Esto es seguro, si falla, currentStatusEnum será el valor predeterminado (0) del enum

                    var isDisabled = IsStateDisabled(currentStatusEnum, state);
                    var buttonColor = GetButtonColor(state);

                    <MudButton 
                        OnClick="(() => SubmitState(state.ToString()))"
                        Disabled="@isDisabled"
                        Color="@buttonColor"
                        FullWidth="false"
                        Class="my-1"
                        Variant="Variant.Filled"
                        style="width: 200px;">
                        @state</MudButton>
                }
            </div>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="Cancel" Color="Color.Default">Cancelar</MudButton>
        </DialogActions>
    </MudDialog>
</div>
<style>
    .custom-dialog {
        backdrop-filter: blur(10px);
    }
</style>
@code {
    [CascadingParameter]
    private MudDialogInstance MudDialog { get; set; }  
    [Parameter]
    public string CurrentState { get; set; }

    // Métodos wrapper para cada botón
    private void OnCloseClick() => SubmitState("Cerrado");
    private void OnPendingClick() => SubmitState("Pendiente");
    private void OnActiveClick() => SubmitState("Activo");

    // Este método se llama cuando el usuario selecciona un estado.
    // Cierra el diálogo y pasa el estado seleccionado como resultado 'Ok'.
    private void SubmitState(string state) => MudDialog.Close(DialogResult.Ok(state));

    // Este método se llama si el usuario hace clic en "Cancelar" o cierra el diálogo.
    // Cierra el diálogo sin un resultado, indicando que fue cancelado.
    private void Cancel() => MudDialog.Cancel();

    private bool IsCloseDisabled() => CurrentState == "Cerrado" || CurrentState == "Finalizado";
    private bool IsPendingDisabled() => CurrentState == "Cerrado" || CurrentState == "Pendiente";
    private bool IsActiveDisabled() => CurrentState == "Cerrado" || CurrentState == "Activo";

    private Color GetButtonColor(WorkOrderStateEnum status)
    {
        return status switch
        {
            WorkOrderStateEnum.Cerrado => Color.Error,
            WorkOrderStateEnum.Pendiente => Color.Warning,
            WorkOrderStateEnum.Activo => Color.Primary,
            _ => Color.Primary, // Color por defecto para otros estados
        };
    }
    private bool IsStateDisabled(WorkOrderStateEnum current, WorkOrderStateEnum target)
    {
        // 1. Siempre deshabilitar si el estado objetivo es el mismo que el actual
        if (current == target)
        {
            return true;
        }

        // 2. Reglas de transición específicas
        switch (current)
        {
            case WorkOrderStateEnum.Cerrado:
                // Si ya está cerrado, no se puede cambiar a ningún otro estado (a menos que permitas "Reabrir")
                return true;
            case WorkOrderStateEnum.Activo:
                // Si está Activo, quizás no se puede volver a Pendiente
                if (target == WorkOrderStateEnum.Activo)
                {
                    return true;
                }
                break;
            case WorkOrderStateEnum.Pendiente:
                // Si está Pendiente, quizás no se puede ir directamente a Cerrado
                if (target == WorkOrderStateEnum.Pendiente)
                {
                    return true;
                }
                break;
        }

        return false; // Por defecto, el botón está habilitado
    }
}
