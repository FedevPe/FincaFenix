
<MudGrid Justify="Justify.Center" Spacing="2" class="w-100">
    <MudItem lg="12" xs="12">
        <MudText Typo="Typo.h6">
            Acciones
        </MudText>
        <MudDivider Style="border-color:black; margin-top: 5px" />            
    </MudItem>
    <MudItem lg="12" xs="12">
        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">
            Agregar Actividad
        </MudButton>
    </MudItem>
    <MudItem xs="12" lg="12">
        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Edit">
            Cambiar estado
        </MudButton>
    </MudItem>
    <MudItem xs="12" lg="12">
        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Custom.FileFormats.FilePdf" OnClick="GeneratePDF">
            Generar pdf
        </MudButton>
    </MudItem>
</MudGrid>
@code {
    [Parameter] public ShowWorkOrderDTO InfoWO { get; set; }

    public void GeneratePDF()
    {
        QuestPDF.Settings.License = QuestPDF.Infrastructure.LicenseType.Community;
        var document = new WorkOrderPDF(InfoWO);
        document.GeneratePdfAndShow();
    }
}