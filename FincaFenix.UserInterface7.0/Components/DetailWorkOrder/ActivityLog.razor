@using System.Collections.Generic
@using System.Linq

<MudDataGrid T="Actividad" Items="@Actividades" SortMode="SortMode.Multiple" Filterable="true" QuickFilter="@_quickFilter" Hideable="false">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Registro de Actividad</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="_searchString" Placeholder="Buscar por Operario" Adornment="Adornment.Start" Immediate="true"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.Fecha" Title="Fecha" Format="dd/MM/yyyy" />
        <PropertyColumn Property="x => x.NombreOperario" Title="Nombre del Operario" />
        <PropertyColumn Property="x => x.CuadroTrabajado" Title="Cuadro Trabajado" />
        <PropertyColumn Property="x => x.HorasTrabajadas" Title="Horas Trabajadas" />
        <PropertyColumn Property="x => x.Rendimiento" Title="Rendimiento" />
    </Columns>
    <PagerContent>
        
    </PagerContent>
</MudDataGrid>


@code {
    private IEnumerable<Actividad> Actividades = new List<Actividad>();
    private string _searchString;

    // Clase de modelo para representar una actividad
    public class Actividad
    {
        public DateTime Fecha { get; set; } = DateTime.Now;
        public string NombreOperario { get; set; }
        public string CuadroTrabajado { get; set; }
        public double HorasTrabajadas { get; set; }
        public double Rendimiento { get; set; }
    }

    // Filtro rápido para buscar por nombre de operario
    private Func<Actividad, bool> _quickFilter => actividad =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (actividad.NombreOperario.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    };

    protected override void OnInitialized()
    {
        // Datos de ejemplo para el registro de actividades
        Actividades = new List<Actividad>
        {
            new Actividad { Fecha = DateTime.Now.AddDays(-2), NombreOperario = "Teofilo Araya", CuadroTrabajado = "A2", HorasTrabajadas = 8, Rendimiento = 15 },
            new Actividad { Fecha = DateTime.Now.AddDays(-1), NombreOperario = "Gustavo Mielniczuk", CuadroTrabajado = "B4", HorasTrabajadas = 7, Rendimiento = 9.5 },
            new Actividad { Fecha = DateTime.Now, NombreOperario = "Alexander Lucero", CuadroTrabajado = "C3", HorasTrabajadas = 8.5, Rendimiento = 8 }
        };
    }
}

