<MudCard Class="info-card h-100" Elevation="3">
    <MudCardContent Class="card-header pa-4 rounded-t-lg">
        <div class="d-flex align-center justify-space-between ">
            <div>
                <MudText Typo="Typo.h5" Class="card-title mb-1">
                    Orden N°@NumWorkOrder
                </MudText>
                <MudText Typo="Typo.body2" Class="card-subtitle">
                    Finca @FarmWorkOrder
                </MudText>
            </div>
            <MudIcon Icon="fa-solid fa-seedling"
                     Class="header-icon"
                     Size="Size.Medium"/>
        </div>
    </MudCardContent>
    
    <MudDivider Class="custom-divider" />
    
    <MudCardContent Class="card-body pa-4">
        <div class="d-flex flex-column align-start">
            <div class="d-flex">
                <MudIcon Icon="fa-solid fa-clipboard"
                         Size="Size.Small"
                         Color="Color.Info"
                         Class="content-icon me-2" />
                <MudText Typo="Typo.body1" Class="content-text">
                    @TaskWorkOrder
                </MudText>
            </div>
            <div class="d-flex mt-1">
                <MudIcon Icon="fa-solid fa-calendar"
                         Size="Size.Small"
                         Color="Color.Primary"
                         Class="content-icon me-2" />
                <MudText Typo="Typo.body1" Class="content-text">
                    @DateWorkOrder.Value.ToShortDateString()
                </MudText>
            </div>
            <MudGrid Class="mt-1" Justify="Justify.FlexStart" Spacing="0">
                <MudItem>
                    <MudChip T="string"
                            Color="ColorText"
                            Variant="Variant.Filled"
                            Size="Size.Small"
                            Class="status-chip"
                            Label="true"
                            Style="color: black">
                        @StatusWorkOrder
                    </MudChip>
                </MudItem>  
                <MudItem>
                    <MudChip T="string"
                             Color="ColorText"
                             Variant="Variant.Text"
                             Size="Size.Small"
                             Class="sector-chip"
                             Label="true"
                             Style="color: black">
                        @if (SectorList != null && SectorList.Any())
                        {                            
                            @string.Join(" - ", SectorList.OrderBy(s => s.SectorName).Select(s => s.SectorName))                            
                        }
                        else
                        {
                            @("No hay cuadros relacionados")
                        }
                    </MudChip>
                </MudItem>
            </MudGrid>
        </div>
    </MudCardContent>
    
    <!-- Footer con acciones (opcional) -->
    <MudCardActions Class="card-actions pa-3 d-flex justify-content-center align-items-center">
        <MudGrid Justify="Justify.Center" Spacing="3">
            <MudItem>
                <MudButton Variant="Variant.Text"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Visibility"
                           Class="action-button"
                           Color="Color.Info"
                           IconColor="Color.Info"
                           OnClick="OpenWorkOrderDetails">Ver Detalles</MudButton>
            </MudItem>
            <MudItem>
                <MudButton Variant="Variant.Text"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.AddTask"
                           Class="action-button"
                           Color="Color.Secondary"
                           IconColor="Color.Secondary"
                           onclick="OpenActivityForm">Registrar Actividad</MudButton>
            </MudItem>
        </MudGrid>
    </MudCardActions>    
</MudCard>

@code {
    [Parameter]
    public string NumWorkOrder { get; set; }
    [Parameter]
    public string FarmWorkOrder { get; set; }
    [Parameter]
    public string TaskWorkOrder { get; set; }
    [Parameter]
    public DateTime? DateWorkOrder { get; set; }
    [Parameter]
    public string StatusWorkOrder { get; set; }
    [Parameter]
    public IEnumerable<DetailSectorFarmDTO> SectorList { get; set; }
    [Parameter]
    public int IdWorkOrder { get; set; }

    private MudBlazor.Color ColorText => StatusWorkOrder switch
    {
        "Cerrado" => MudBlazor.Color.Error,
        "Pendiente" => MudBlazor.Color.Warning,
        "Activo" => MudBlazor.Color.Secondary,
        _ => MudBlazor.Color.Default
    };

    [Inject] private NavigationManager NavigationManager { get; set; }
    [Inject] private ISnackbar Snackbar { get; set; }

    public void OpenActivityForm()
    {
        if(StatusWorkOrder == "Activo")
        {
            NavigationManager.NavigateTo($"/actividad/registrar/{IdWorkOrder}");
        }
        else
        {
            Snackbar.Add($"La orden de trabajo N° {IdWorkOrder} no se encuentra activa.", MudBlazor.Severity.Warning);
        }
    }
    public void OpenWorkOrderDetails()
    {
        NavigationManager.NavigateTo($"/ordentrabajo/{IdWorkOrder}/detalle/");
    }
}

<style>
.info-card {
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
}
.info-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15) !important;
}
.card-header {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-radius: 12px 12px 0 0;
}
.card-title {
    font-weight: 600;
    color: #2c3e50;
    letter-spacing: -0.5px;
}
.card-subtitle {
    color: #6c757d;
    font-weight: 500;
}
.header-icon {
    color: #28a745;
    opacity: 0.8;
}
.custom-divider {
    height: 5px;
    background: linear-gradient(90deg, transparent, #dee2e6, transparent);
}
.card-body {
    padding: 1.5rem !important;
    height: 100%;
}
.content-icon {
    color: #17a2b8;
}
.content-text {
    color: #495057;
    font-weight: 500;
}
.card-actions {
    background-color: #f8f9fa;
    border-radius: 0 0 12px 12px;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    width: 100%;
}
.action-button {
    color: #004D40;
    font-weight: 500;
    text-transform: none;
}
.action-button:hover {
    background-color: rgba(0, 123, 255, 0.04);
}
.info-card:focus-within {
    outline: 2px solid #004D40;
    outline-offset: 2px;
}
.status-chip {
    border: 1px solid;
    color: white !important;
}
.sector-chip{
    border: 1px solid;
}
</style>

