<MudDialog>
    <TitleContent>
        <div class="modal-title-container">
            <MudIcon Icon="@Icons.Material.Filled.Logout" Class="modal-title-icon" />
            <MudText Typo="Typo.h6">Cerrar Sesión</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="modal-body-content">
            <!-- Mensaje de confirmación -->
            <div class="confirmation-section">
                <div class="confirmation-icon-container">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Class="user-icon" />
                </div>
                <div class="confirmation-content">
                    <MudText Typo="Typo.body1" Class="confirmation-title">
                        ¿Estás seguro de que deseas cerrar sesión?
                    </MudText>
                    <MudText Typo="Typo.body2" Class="confirmation-description">
                        Se cerrará tu sesión actual y tendrás que volver a iniciar sesión para acceder al sistema.
                    </MudText>
                </div>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelLogout" Class="cancel-button">
            Cancelar
        </MudButton>
        <MudButton Color="Color.Error"
                   OnClick="ConfirmLogout"
                   Disabled="@isProcessing"
                   Class="logout-button">
            @if (isProcessing)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Cerrando sesión...</MudText>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.Logout" Class="me-2" />
                <span>Cerrar Sesión</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; }

    [Inject] private ISnackbar Snackbar { get; set; }
    [Inject] private NavigationManager NavigationManager { get; set; }
    // [Inject] private IAuthService AuthService { get; set; } // Descomenta según tu servicio de autenticación

    private bool isProcessing = false;

    private void CancelLogout()
    {
        MudDialog.Cancel();
    }

    private async Task ConfirmLogout()
    {
        isProcessing = true;
        StateHasChanged();

        try
        {
            await Task.Delay(2000);
            NavigationManager.NavigateTo("/Account/Logout", forceLoad: true);

            Snackbar.Add("Sesión cerrada correctamente", MudBlazor.Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));

            // Redirigir a la página de login
            // NavigationManager.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cerrar sesión: {ex.Message}", MudBlazor.Severity.Error);
            MudDialog.Close(DialogResult.Cancel());
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }
}

<style>
    .modal-title-container {
        display: flex;
        align-items: center;
        gap: 12px;
    }

