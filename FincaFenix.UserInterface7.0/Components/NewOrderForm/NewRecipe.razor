    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    margin: 1.5rem 0;
    border: 1px solid rgba(0, 0, 0, 0.06);
}
/* Header Styles */
