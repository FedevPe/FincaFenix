<MudForm @ref="_form" Model="ViewModel" Validation="@(Validator.ValidateValue)">
    <div class="materials-container">
        <!-- Header Section -->
        <div class="materials-header">
            <div class="header-content">
                <div class="header-icon-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.FormatListBulleted" Class="header-icon" />
                </div>
                <div class="header-text">
                    <MudText Class="header-title" Typo="Typo.h4">Lista de materiales</MudText>
                    <MudText Class="header-subtitle" Typo="Typo.subtitle1">Agregue los materiales necesarios para la orden de trabajo</MudText>
                </div>
                <div class="header-actions">
                    <MudButton Variant="Variant.Filled" 
                             Color="Color.Info"
                             Size="Size.Medium"
                             StartIcon="@Icons.Material.Filled.Add"
                             Class="action-btn recipe-btn"
                             @onclick="AddRecipe" 
                             Disabled="_recipeInitialized">
                        Crear Receta
                    </MudButton>
                    <MudButton Variant="Variant.Filled" 
                             Color="Color.Primary"
                             Size="Size.Medium"
                             StartIcon="@Icons.Material.Filled.Add" 
                             Class="action-btn material-btn"
                             Disabled="@(!_recipeInitialized)"
                             @onclick="AddMaterial">
                        Agregar Insumo
                    </MudButton>
                </div>
            </div>
            <div class="header-divider"></div>
        </div>

        <!-- Machine Configuration Section con Validaciones Implementadas -->
        @if (ViewModel.Machine != null)
        {
            <MudForm @ref="_form" Model="ViewModel.Machine" Validation="@(ValidatorMachine.ValidateValue)">
                <div class="materials-table-section">
                    <div class="materials-table-section">
                        <div class="table-header">
                            <!-- Header de la sección -->
                            <div class="table-header-content">
                                <div class="field-label">
                                    <MudIcon Icon="@Icons.Material.Filled.Build" Class="table-header-icon" />
                                    <MudText Class="table-header-title" Typo="Typo.h6">Maquinaria</MudText>
                                </div>
                            </div>
                        </div>

                        <div class="materials-table-container">
                            <!-- Tabla de maquinaria -->
                            <MudTable T="MachineRecipeDTO"
                                      Items="@(new List<MachineRecipeDTO> { ViewModel.Machine })"
                                      Class="materials-table"
                                      Bordered="true"
                                      Dense="true"
                                      Hover="true"
                                      Elevation="0">
                                <HeaderContent>
                                    <MudTh Class="materials-table-header">
                                        <div class="header-content">
                                            <MudIcon Icon="@Icons.Material.Filled.Build" Class="header-icon" />
                                            <span>Maquinaria</span>
                                        </div>
                                    </MudTh>
                                    <MudTh Class="materials-table-header">
                                        <div class="header-content">
                                            <MudIcon Icon="@Icons.Material.Filled.Water" Class="header-icon" />
                                            <span>Volumen</span>
                                        </div>
                                    </MudTh>
                                    <MudTh Class="materials-table-header">
                                        <div class="header-content">
                                            <MudIcon Icon="@Icons.Material.Filled.Scale" Class="header-icon" />
                                            <span>Unidad</span>
                                        </div>
                                    </MudTh>
                                    <MudTh Class="materials-table-header">
                                        <div class="header-content">
                                            <MudIcon Icon="@Icons.Material.Filled.Speed" Class="header-icon" />
                                            <span>TRV</span>
                                        </div>
                                    </MudTh>
                                    <MudTh Class="materials-table-header">
                                        <div class="header-content">
                                            <MudIcon Icon="@Icons.Material.Filled.Settings" Class="header-icon" />
                                            <span>Acciones</span>
                                        </div>
                                    </MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd Class="materials-table-cell">
                                        <!-- Selector de Maquinaria con validación -->
                                        <MudSelect T="int"
                                                   @bind-Value="context.Id"
                                                   @bind-Value:event="onchange"
                                                   ValueChanged="OnMachineSelected"
                                                   Margin="Margin.Dense"
                                                   Variant="Variant.Text"
                                                   AnchorOrigin="Origin.BottomCenter"
                                                   TransformOrigin="Origin.TopCenter"
                                                   For="@(() => context.Id)"
                                                   Validation="@(ValidatorMachine.ValidateValue)"
                                                   Class="table-select"
                                                   Clearable>
                                            <MudSelectItem T="int" Value="0" Disabled="true">Seleccione un elemento</MudSelectItem>
                                            @foreach (var machine in ViewModel.MachineList)
                                            {
                                                <MudSelectItem T="int" Value="@machine.Id">@machine.Name</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudTd>

                                    <MudTd Class="materials-table-cell">
                                        @if (context.Id != 0)
                                        {
                                            <!-- Campo de Capacidad con validación -->
                                            <MudNumericField T="decimal"
                                                             @bind-Value="context.Capacity"
                                                             Min="0.00m"
                                                             Format="N2"
                                                             Margin="Margin.Dense"
                                                             Variant="Variant.Text"
                                                             For="@(() => context.Capacity)"
                                                             Validation="@(ValidatorMachine.ValidateValue)"
                                                             Class="table-numeric"
                                                             Placeholder="Ingrese capacidad"/>
                                        }
                                        else
                                        {
                                            <MudText Class="text-muted" Typo="Typo.body2">-</MudText>
                                        }
                                    </MudTd>

                                    <MudTd Class="materials-table-cell">
                                        @if (context.Id != 0)
                                        {
                                            <!-- Mostrar unidad de capacidad -->
                                            <MudText Typo="Typo.body1" Class="unit-text">@context.CapacityUnit</MudText>
                                        }
                                        else
                                        {
                                            <MudText Class="text-muted" Typo="Typo.body2">-</MudText>
                                        }
                                    </MudTd>

                                    <MudTd Class="materials-table-cell">
                                        @if (context.Id != 0)
                                        {
                                            <!-- Campo TRV con validación -->
                                            <MudNumericField T="decimal"
                                                             Min="0.00m"
                                                             Format="N2"
                                                             Margin="Margin.Dense"
                                                             Variant="Variant.Text"
                                                             @bind-Value="context.TRV"
                                                             For="@(() => context.TRV)"
                                                             Validation="@(ValidatorMachine.ValidateValue)"
                                                             Class="table-numeric"
                                                             Adornment="Adornment.End"
                                                             AdornmentText="lts/ha"
                                                             Placeholder="Ingrese TRV" />
                                        }
                                        else
                                        {
                                            <MudText Class="text-muted" Typo="Typo.body2">-</MudText>
                                        }
                                    </MudTd>

                                    <MudTd Class="materials-table-cell">
                                        @if (context.Id != 0)
                                        {
                                            <div class="table-actions">
                                                <MudTooltip Text="Calcular TRV">
                                                    <MudButton Variant="Variant.Filled"
                                                               Color="Color.Info"
                                                               Size="Size.Small"
                                                               StartIcon="@Icons.Material.Filled.Calculate"
                                                               Class="action-btn"
                                                               OnClick="OpenTRVCalculatorDialog">
                                                        CALCULAR TRV
                                                    </MudButton>
                                                </MudTooltip>
                                            </div>
                                        }
                                        else
                                        {
                                            <MudText Class="text-muted" Typo="Typo.body2">-</MudText>
                                        }
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        </div>
                    </div>
                </div>
            </MudForm>
        }

        <!-- Materials Table Section -->
        @if (ViewModel.Details.Count() != 0)
        {
            <div class="materials-table-section mb-4">
                <div class="table-header">
                    <div class="table-header-content">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory" Class="table-header-icon" />
                        <MudText Class="table-header-title" Typo="Typo.h6">Materiales</MudText>
                    </div>
                </div>

                <div class="materials-table-container">
                    <MudTable T="DetailRecipeDTO" 
                            Items="@ViewModel.Details" 
                            Class="materials-table" 
                            Bordered="true" 
                            Dense="true" 
                            Hover="true"
                            Elevation="0"
                            Breakpoint="Breakpoint.Sm">
                        <HeaderContent>
                            <MudTh Class="materials-table-header">
                                <div class="header-content">
                                    <MudIcon Icon="@Icons.Material.Filled.Category" Class="header-icon" />
                                    <span>Categoría</span>
                                </div>
                            </MudTh>
                            <MudTh Class="materials-table-header">
                                <div class="header-content">
                                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" Class="header-icon" />
                                    <span>Producto</span>
                                </div>
                            </MudTh>
                            <MudTh Class="materials-table-header">
                                <div class="header-content">
                                    <MudIcon Icon="@Icons.Material.Filled.BrandingWatermark" Class="header-icon" />
                                    <span>Marca</span>
                                </div>
                            </MudTh>
                            <MudTh Class="materials-table-header">
                                <div class="header-content">
                                    <MudIcon Icon="@Icons.Material.Filled.BugReport" Class="header-icon" />
                                    <span>Plaga/Enfermedad</span>
                                </div>
                            </MudTh>
                            <MudTh Class="materials-table-header">
                                <div class="header-content">
                                    <MudIcon Icon="@Icons.Material.Filled.Scale" Class="header-icon" />
                                    <span>Dosis</span>
                                </div>
                            </MudTh>
                            <MudTh Class="materials-table-header">
                                <div class="header-content">
                                    <MudIcon Icon="@Icons.Material.Filled.Straighten" Class="header-icon" />
                                    <span>Unidad</span>
                                </div>
                            </MudTh>
                            <MudTh Class="materials-table-header">
                                <div class="header-content">
                                    <MudIcon Icon="@Icons.Material.Filled.Calculate" Class="header-icon" />
                                    <span>Cant. Estimada</span>
                                </div>
                            </MudTh>
                            <MudTh Class="materials-table-header">
                                <div class="header-content">
                                    <MudIcon Icon="@Icons.Material.Filled.Settings" Class="header-icon" />
                                    <span>Acciones</span>
                                </div>
                            </MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Class="materials-table-cell">
                                <MudForm Model="@context" Validation="@(ValidatorDetail.ValidateValue)">
                                    <MudSelect T="int"
                                             Margin="Margin.Dense"
                                             Variant="Variant.Text"
                                             AnchorOrigin="Origin.BottomCenter"
                                             TransformOrigin="Origin.TopCenter"
                                             @bind-Value="context.CategoryId"
                                             For="@(() => context.CategoryId)"
                                             Class="table-select"
                                             Clearable>
                                        <MudSelectItem T="int" Value="0" Disabled="true">Seleccione una categoría</MudSelectItem>
                                        @if (ViewModel.Categories != null)
                                        {
                                            @foreach (var category in ViewModel.Categories)
                                            {
                                                <MudSelectItem T="int" Value="@category.Id">@category.Description</MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                </MudForm>
                            </MudTd>
                            <MudTd Class="materials-table-cell">
                                <MudForm Model="@context" Validation="@(ValidatorDetail.ValidateValue)">
                                    <MudSelect T="int"
                                             Margin="Margin.Dense"
                                             Variant="Variant.Text"
                                             AnchorOrigin="Origin.BottomCenter"
                                             TransformOrigin="Origin.TopCenter"
                                             @bind-Value="context.MaterialId"
                                             For="@(() => context.MaterialId)"
                                             Class="table-select"
                                             Clearable>
                                        <MudSelectItem T="int" Value="0" Disabled="true">Seleccione un producto</MudSelectItem>
                                        @foreach (var m in GetAvailableMaterials(context.CategoryId))
                                        {
                                            <MudSelectItem T="int" Value="@m.Id">@m.ArticleName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudForm>
                            </MudTd>
                            <MudTd Class="materials-table-cell">
                                <MudForm Model="@context" Validation="@(ValidatorDetail.ValidateValue)">
                                    <MudTextField @bind-Value="context.Brand" 
                                                Placeholder="Marca" 
                                                Variant="Variant.Text"
                                                Class="table-input"
                                                For="@(() => context.Brand)" />
                                </MudForm>
                            </MudTd>
                            <MudTd Class="materials-table-cell">
                                <MudForm Model="@context" Validation="@(ValidatorDetail.ValidateValue)">
                                    <MudTextField @bind-Value="context.PestDisease" 
                                                Placeholder="Plaga/Enfermedad" 
                                                Variant="Variant.Text"
                                                Class="table-input"
                                                For="@(() => context.PestDisease)" />
                                </MudForm>
                            </MudTd>
                            <MudTd Class="materials-table-cell">
                                <MudForm Model="@context" Validation="@(ValidatorDetail.ValidateValue)">
                                    <MudNumericField T="decimal"
                                                   Format="N2"
                                                   Margin="Margin.Dense"
                                                   Variant="Variant.Text"
                                                   @bind-Value="context.AmountRequired"
                                                   Adornment="Adornment.End"
                                                   AdornmentText="@context.AmountRequiredUnit"
                                                   Class="table-numeric"
                                                   For="@(() => context.AmountRequired)" />
                                </MudForm>
                            </MudTd>
                            <MudTd Class="materials-table-cell">
                                <MudForm Model="@context" Validation="@(ValidatorDetail.ValidateValue)">
                                    <MudSelect T="string"
                                             Margin="Margin.Dense"
                                             Variant="Variant.Text"
                                             AnchorOrigin="Origin.BottomCenter"
                                             TransformOrigin="Origin.TopCenter"
                                             @bind-Value="context.AmountRequiredUnit"
                                             For="@(() => context.AmountRequiredUnit)"
                                             Class="table-select unit-select"
                                             @bind-Value:after="(() => CalculateEstimatedAmount(context))">
                                        <MudSelectItem Value="@("kg")">kg</MudSelectItem>
                                        <MudSelectItem Value="@("gr")">gr</MudSelectItem>
                                        <MudSelectItem Value="@("lts")">lts</MudSelectItem>
                                        <MudSelectItem Value="@("cc")">cc</MudSelectItem>
                                    </MudSelect>
                                </MudForm>
                            </MudTd>
                            <MudTd Class="materials-table-cell">
                                <div class="estimated-amount">
                                    <MudChip T="string" Size="Size.Small" 
                                           Variant="Variant.Filled" 
                                           Color="Color.Success"
                                           Class="amount-chip">
                                        @context.EstimatedAmount.ToString("F") @context.EstimatedAmountUnit
                                    </MudChip>
                                </div>
                            </MudTd>
                            <MudTd Class="materials-table-cell">
                                <div class="table-actions">
                                    <MudTooltip Text="Calcular cantidad">
                                        <MudIconButton Icon="fa-solid fa-calculator"
                                                     Color="Color.Info"
                                                     Variant="Variant.Text"
                                                     Size="Size.Small"
                                                     Class="action-btn calc-btn"
                                                     @onclick="@(() => CalculateEstimatedAmount(context))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Eliminar material">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                     Color="Color.Error"
                                                     Variant="Variant.Text"
                                                     Size="Size.Small"
                                                     Class="action-btn delete-btn"
                                                     @onclick="@(() => RemoveMaterial(context))" />
                                    </MudTooltip>
                                </div>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
            </div>
        }
    </div>
</MudForm>
@code{
    private bool _recipeInitialized = false;

    [Inject] private IDialogService DialogService { get; set; }
    [Inject] private ISnackbar SnackbarService { get; set; }
    [Inject] private TotalAreaSectorService TotalAreaSectorService { get; set; }
    [Inject] public NewRecipeUIValidator Validator { get; set; }
    [Inject] public NewDetailRecipeUIValidator ValidatorDetail { get; set; }
    [Inject] public RecipeMachineUIValidator ValidatorMachine { get; set; }
    [Parameter] public NewRecipeViewModel ViewModel { get; set; }

    private MudForm _form;

    protected override void OnInitialized()
    {
        TotalAreaSectorService.OnChange += StateHasChanged;
    }
    private IEnumerable<MaterialRecipeDTO> GetAvailableMaterials(int contextCategoryId)
    {
        return ViewModel.Materials.Where(m => m.CategoryId == contextCategoryId)
           .DistinctBy(m => m.ArticleName)
           .ToList();
    }
    public void Dispose()
    {
        TotalAreaSectorService.OnChange -= StateHasChanged;
    }
    private void OnMachineSelected(int id)
    {
        ViewModel.Machine.Id = id;
        var machine = ViewModel.MachineList?.FirstOrDefault(m => m.Id == id);
        if (machine is not null)
        {
            ViewModel.Machine = machine;
        }
    }
    private async Task OpenTRVCalculatorDialog()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = false };
        var dialog = DialogService.Show<CalculatorTRVDialog>("Calculadora TRV", options); // Asegúrate que TRVCalculatorDialog es el nombre de tu componente de diálogo

        var result = await dialog.Result; // Esto espera a que el diálogo se cierre

        if (!result.Canceled) // Si el usuario no canceló el diálogo
        {
            // Intentamos obtener el resultado como un decimal
            if (result.Data is decimal trvValue)
            {
                ViewModel.Machine.TRV = trvValue;
                StateHasChanged();
            }
        }
    }
    private void AddMaterial()
    {
        if (_recipeInitialized)
        {
            ViewModel.AddMaterial();
        }
    }
    private void RemoveMaterial(DetailRecipeDTO material)
    {
        ViewModel.RemoveMaterial(material);
        if (!ViewModel.Details.Any() && ViewModel.Machine == null) _recipeInitialized = false;
    }
    private void AddRecipe()
    {
        if (!_recipeInitialized)
        {
            ViewModel.InitializeRecipe(TotalAreaSectorService.TotalAreaSectors);
            _recipeInitialized = true;
        }
        StateHasChanged();
    }
    private void CalculateEstimatedAmount(DetailRecipeDTO detail)
    {
        try
        {
            if (detail.AmountRequired <= 0)
            {
                SnackbarService.Add("La 'Dosis' no es válida para el cálculo.", MudBlazor.Severity.Warning);
                return;
            }

            detail.EstimatedAmount = ViewModel.CalculateEstimateAmount(
                ViewModel.Machine.TRV,
                detail.AmountRequired,
                ViewModel.Machine.Capacity,
                TotalAreaSectorService.TotalAreaSectors,
                detail.AmountRequiredUnit
            );

            if (detail.AmountRequiredUnit == "lts" || detail.AmountRequiredUnit == "cc")
            {
                detail.EstimatedAmountUnit = "lts";
            }
            else
            {
                detail.EstimatedAmountUnit = "kg";
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            // Loguear la excepción para depuración (opcional, pero recomendado en aplicaciones reales)
            Console.WriteLine($"Error al calcular la cantidad estimada: {ex.Message}");
            SnackbarService.Add("Ocurrió un error al calcular la cantidad estimada. Verifique los valores ingresados.", MudBlazor.Severity.Error);
            detail.EstimatedAmount = 0;
            StateHasChanged();
        }
    }
}
<style>
