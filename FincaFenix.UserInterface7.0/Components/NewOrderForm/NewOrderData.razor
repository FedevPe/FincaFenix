                                                   Color="Color.Error"
                                                   Variant="Variant.Text"
                                                   Size="Size.Medium"
                                                   OnClick="(() => RemoveSectorFromSelection(context))" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>                       
                    </MudItem>
                    <MudItem xs="12" lg="12">
                        <MudDivider Style="border-color: black" />
                    </MudItem>
                    <MudItem xs="12" lg="12">
                        <MudText Typo="Typo.body1"><b>Superficie Total: </b>@TotalArea ha.</MudText>
                    </MudItem>
                }
            }
        </MudGrid>
    </div>
</MudForm> *@