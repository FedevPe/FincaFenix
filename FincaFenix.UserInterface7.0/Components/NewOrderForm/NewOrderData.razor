<div class="container-fluid shadow rounded p-4 bg-color-white">
    <MudGrid>
        <MudItem lg="12">
            <MudText Typo="Typo.h4">Nueva Orden de Trabajo</MudText>
            <MudText Typo="Typo.subtitle1">Complete la información necesaria para crear la orden</MudText>
        </MudItem>
    </MudGrid>

    <MudDivider Style="border-color: black;" />

    <MudGrid Spacing="3" Justify="Justify.FlexStart" Class="mt-3">
        <MudItem xs="12" lg="6">
            <MudText Typo="Typo.h6">Finca</MudText>
            <MudSelect T="int" Margin="Margin.Dense" FullWidth="true"
                       Variant="Variant.Outlined" Clearable
                       AnchorOrigin="Origin.BottomLeft"
                       TransformOrigin="Origin.BottomLeft"
                       @bind-Value="_selectedFarm"
                       @bind-Value:event="onchange"
                       ValueChanged="@OnFarmChanged">                
                <MudSelectItem T="int" Value="0" Disabled="true">Seleccione una finca</MudSelectItem>
                @foreach (var farm in ViewModel.Farms)
                {
                    <MudSelectItem T="int" Value="@farm.Id">@farm.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        <MudItem xs="12" lg="6">
            <MudText Typo="Typo.h6">Tarea</MudText>
            <MudSelect  Margin="Margin.Dense" FullWidth="true"
                       Variant="Variant.Outlined" Clearable
                       AnchorOrigin="Origin.BottomLeft"
                       TransformOrigin="Origin.BottomLeft"
                       @bind-Value="_selectedTask"
                       @bind-Value:event="onchange">
                <MudSelectItem T="int" Value="0" Disabled="true">Seleccione una tarea</MudSelectItem>
                @foreach (var task in ViewModel.Tasks)
                {
                    <MudSelectItem T="int" Value="@task.Id">@task.Description</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        @if(_selectedFarm != 0)
        {
            <MudItem xs="12" lg="12">
                <MudText Typo="Typo.h6">Sectores de la finca</MudText>
            </MudItem>
        }

        @* <MudFlexBreak /> *@

        <MudItem xs="12" lg="12">
            <MudGrid Justify="Justify.SpaceEvenly">
                <MudItem xs="12" sm="6" lg="3">
                    @foreach (var sector in ColumnSector1)
                    {
                        <MudCheckBox T="bool"
                                     @bind-Value="@sector.Selected"
                                     Label="@sector.SectorName"
                                     CheckedChanged="@(async (bool value) => { sector.Selected = value; await OnSectorSelectionChanged(sector, value); })"
                                     Color="Color.Primary" />
                    }
                </MudItem>

                <MudItem xs="12" sm="6" lg="3">
                    @foreach (var sector in ColumnSector2)
                    {
                        <MudCheckBox T="bool"
                                     @bind-Value="@sector.Selected"
                                     Label="@sector.SectorName"
                                     CheckedChanged="@(async (bool value) => { sector.Selected = value; await OnSectorSelectionChanged(sector, value); })"
                                     Color="Color.Primary" />
                    }
                </MudItem>
                <MudItem xs="12" sm="6" lg="3">
                    @foreach (var sector in ColumnSector3)
                    {
                        <MudCheckBox T="bool"
                                     @bind-Value="@sector.Selected"
                                     Label="@sector.SectorName"
                                     CheckedChanged="@(async (bool value) => { sector.Selected = value; await OnSectorSelectionChanged(sector, value); })"
                                     Color="Color.Primary" />
                    }
                </MudItem>
                <MudItem xs="12" sm="6" lg="3">
                    @foreach (var sector in ColumnSector4)
                    {
                        <MudCheckBox T="bool"
                                     @bind-Value="@sector.Selected"
                                     Label="@sector.SectorName"
                                     CheckedChanged="@(async (bool value) => { sector.Selected = value; await OnSectorSelectionChanged(sector, value); })"
                                     Color="Color.Primary" />
                    }
                </MudItem>
            </MudGrid>
        </MudItem>
    </MudGrid>
</div>
<MudText>Seleccionados: @ViewModel.SelectedSectors.Count()</MudText>

