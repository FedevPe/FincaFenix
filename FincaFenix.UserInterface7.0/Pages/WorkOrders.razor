@page "/ordenestrabajo"
@inject AuthenticationStateProvider AuthenticationStateProvider
@attribute [Authorize]

<AuthorizeView Roles="admin, desarrollador">
    <div class="mt-3 mb-3">
        <MudGrid Justify="Justify.FlexEnd" Class="mb-2 g-3">
            <MudItem>
                <MudButton Href="/createOrder" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add">Nueva Orden</MudButton>
            </MudItem>
        </MudGrid>
    </div>
</AuthorizeView>
<div class="container-fluid shadow p-3 border rounded mt-3 mb-3 bg-color-white">
    <AuthorizeView Roles="admin, desarrollador, supervisor">
        <StatsCard WorkOrderList="@ViewModel.AllWorkOrderList" OnFilterSelectedChanged="HandleFilterSelected" />
    </AuthorizeView>
    <MudGrid Justify="Justify.FlexStart" Spacing="1">
        <MudItem>
            <MudText Typo="Typo.h5"><b>Ordenes de Trabajo</b></MudText>
        </MudItem>
        <MudSpacer />
        <AuthorizeView Roles="desarrollador">
            <MudToggleGroup T="bool" Value="renderWorkOrderCard" ValueChanged="HandleToggleChanged">
                <MudToggleItem Value="true">
                    <ChildContent Context="iconContent">
                        <MudIcon Icon="@Icons.Material.Filled.ViewModule"
                                 Style="@($"color: {(renderWorkOrderCard ? Colors.Shades.White : Colors.Teal.Darken4)};")"
                                 Size="MudBlazor.Size.Small" />
                    </ChildContent>
                </MudToggleItem>
                <MudToggleItem Value="false">
                    <ChildContent Context="iconContent">
                        <MudIcon Icon="@Icons.Material.Filled.ViewList"
                                 Style="@($"color: {(renderWorkOrderCard ? Colors.Teal.Darken4 : Colors.Shades.White)};")"
                                 Size="MudBlazor.Size.Small" />
                    </ChildContent>
                </MudToggleItem>
            </MudToggleGroup>
        </AuthorizeView>
    </MudGrid>

    <MudDivider Class="my-2" Style="border-color: black;" />

    @if (_isLoading)
    {
        <div class="d-flex flex-column align-items-center justify-content-center" style="height: 200px;">
            <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
            <MudText Typo="Typo.h6" Style="margin-top:30px">Cargando órdenes de trabajo...</MudText>
        </div>
    }
    else if ((_workOrderList is null || !_workOrderList.Any()))
    {
        <MudItem xs="12">
            <div class="empty-state-card">
                <div class="empty-state-content">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="empty-state-icon" />
                    <MudText Typo="Typo.h6" Class="empty-state-title">No se han encontrado ordenes.</MudText>
                    <MudText Typo="Typo.body1" Class="empty-state-description">
                        Ninguna orden cumple con el criterio de busqueda.
                    </MudText>
                </div>
            </div>
        </MudItem>
    }
    else
    {
        @if (renderWorkOrderCard)
        {
            <AuthorizeView Roles="operario, desarrollador">
                @if (_filteredWorkOrderList.Any())
                {
                    <MudGrid Spacing="3" Justify="Justify.FlexStart" class="mt-1">
                        @foreach (var workorder in _filteredWorkOrderList.Skip((ViewModel.CurrentPage - 1) * ViewModel.PageSize).Take(ViewModel.PageSize))
                        {
                            <MudItem xs="12" sm="12" md="6" lg="3">
                                <WorkOrderCard InfoWO="workorder" />
                            </MudItem>
                        }
                    </MudGrid>
                    @if (_filteredWorkOrderList.Count() > ViewModel.PageSize)
                    {
                        <div class="w-100 d-flex flex-column align-items-center mt-4">
                            <MudPagination Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Count="@((int)Math.Ceiling((double)_filteredWorkOrderList.Count() / ViewModel.PageSize))"
                                           Selected="@ViewModel.CurrentPage"
                                           SelectedChanged="ViewModel.OnPageChanged" />
                        </div>
                    }
                }
                else
                {
                    <MudItem xs="12">
                        <div class="empty-state-card">
                            <div class="empty-state-content">
                                <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="empty-state-icon" />
                                <MudText Typo="Typo.h6" Class="empty-state-title">No se han encontrado ordenes.</MudText>
                                <MudText Typo="Typo.body1" Class="empty-state-description">
                                    No hay ordenes de trabajo activas.
                                </MudText>
                            </div>
                        </div>
                    </MudItem>
                }
            </AuthorizeView>
        }
        else
        {
            <AuthorizeView Roles="admin, desarrollador, supervisor">
                <MudItem xs="12" lg="12">
                    <WorkOrderTable WorkOrderList="@_workOrderList" />
                </MudItem>
            </AuthorizeView>
        }   
    }
</div>
@code{
    [Inject] public LoadWorkOrdersViewModel ViewModel { get; set; }
    [Inject] public TextAppBarStateService TextApp { get; set; }

    private bool renderWorkOrderCard = true;
    private bool _isLoading = true;
    private IEnumerable<ShowWorkOrderDTO> _workOrderList;
    private IEnumerable<ShowWorkOrderDTO> _filteredWorkOrderList = new List<ShowWorkOrderDTO>();

    protected override async Task OnInitializedAsync()
    {
        TextApp.PageTitle = "Ordenes de Trabajo";

        await LoadDataAsync();
        _workOrderList = ViewModel.AllWorkOrderList;
        await GetFilteredWorkOrdersForOperario();
    }

    private async Task HandleToggleChanged(bool value)
    {
        renderWorkOrderCard = value;
        await LoadDataAsync();
    }
    private async Task GetFilteredWorkOrdersForOperario()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        // Si el usuario es un operario, aplicar el filtro
        if (user.IsInRole("operario"))
        {
            renderWorkOrderCard = true;
            if(user.Identity.Name == "fsancarlos")
            {
                _filteredWorkOrderList = _workOrderList.Where(x => x.Status == "Activo" && x.Farm.Id == 1);
            }
            else if(user.Identity.Name == "fgoudge")
            {
                _filteredWorkOrderList = _workOrderList.Where(x => x.Status == "Activo" && x.Farm.Id == 2);
            }
            else
            {
                _filteredWorkOrderList = _workOrderList.Where(x => x.Status == "Activo" && x.Farm.Id == 3);
            }
        }
        else if (user.IsInRole("desarrollador"))
        {
            renderWorkOrderCard = true;
            _filteredWorkOrderList = _workOrderList;
        }
        else
        {
            renderWorkOrderCard = false;
        }
        StateHasChanged(); // Forzar la actualización del componente
    }
    private async Task LoadDataAsync()
    {        
        await ViewModel.LoadWorkOrderList();
        _isLoading = false;
        StateHasChanged();
    }
    private void HandleFilterSelected(StatsCard.FilterWorkOrder filter)
    {
        ViewModel.CurrentPage = 1;
        // Aplica la lógica de filtrado en el componente padre.
        switch (filter)
        {
            case StatsCard.FilterWorkOrder.Active:
                _workOrderList = ViewModel.AllWorkOrderList.Where(wo => wo.Status == "Activo").ToList();
                _filteredWorkOrderList = ViewModel.AllWorkOrderList.Where(wo => wo.Status == "Activo").ToList();
                break;
            case StatsCard.FilterWorkOrder.Pending:
                _workOrderList = ViewModel.AllWorkOrderList.Where(wo => wo.Status == "Pendiente").ToList();
                _filteredWorkOrderList = ViewModel.AllWorkOrderList.Where(wo => wo.Status == "Pendiente").ToList();
                break;
            case StatsCard.FilterWorkOrder.Closed:
                _workOrderList = ViewModel.AllWorkOrderList.Where(wo => wo.Status == "Cerrado").ToList();
                _filteredWorkOrderList = ViewModel.AllWorkOrderList.Where(wo => wo.Status == "Cerrado").ToList();
                break;
            case StatsCard.FilterWorkOrder.None:
            default:
                _workOrderList = ViewModel.AllWorkOrderList;
                _filteredWorkOrderList = ViewModel.AllWorkOrderList;
                break;
        }
        StateHasChanged();
    }
}
<style>
    /* Empty State Styles */
    .empty-state-card {
        background: #f8fafc;
        border-radius: 16px;
        padding: 3rem 2rem;
        border: 1px solid #e2e8f0;
        margin: 1rem 0;
        transition: all 0.3s ease;
    }

    .empty-state-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 1rem;
    }

    .empty-state-icon {
        font-size: 48px !important;
        color: #94a3b8 !important;
        opacity: 0.7;
        margin-bottom: 0.5rem;
    }

    .empty-state-title {
        color: #475569 !important;
        font-weight: 600 !important;
        margin: 0 !important;
    }

    .empty-state-description {
        color: #64748b !important;
        max-width: 400px !important;
        line-height: 1.6 !important;
        margin: 0 !important;
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .empty-state-card

    {
        padding: 2rem 1.5rem;
    }

    .empty-state-icon {
        font-size: 40px !important;
    }

    .empty-state-description {
        max-width: 300px !important;
        font-size: 0.9rem !important;
    }

    }

    @@media (max-width: 480px) {
        .empty-state-card

    {
        padding: 1.5rem 1rem;
        margin: 0.5rem 0;
    }

    .empty-state-icon {
        font-size: 36px !important;
    }

    }
</style>


