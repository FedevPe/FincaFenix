@page "/ordenestrabajo"
@using FincaFenix.ViewModels.ViewModels.WorkOrder.GetInformationWorkOrder
@attribute [Authorize]

<div class="mt-3 mb-3">
    <MudGrid Justify="Justify.FlexEnd" Class="mb-2 g-3">
        <MudItem>
            <MudButton Href="/createOrder" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add">Nueva Orden</MudButton>
        </MudItem>
    </MudGrid>
</div>
<div class="container-fluid shadow p-3 border rounded mt-3 mb-3 bg-color-white">
    <StatsCard WorkOrderList="@ViewModel.AllWorkOrderList" OnFilterSelectedChanged="HandleFilterSelected" />
    <MudGrid Justify="Justify.FlexStart" Spacing="1">
        <MudItem>
            <MudText Typo="Typo.h5"><b>Ordenes de Trabajo</b></MudText>
        </MudItem>
        <MudSpacer />
        <MudToggleGroup T="bool" Value="renderWorkOrderCard" ValueChanged="HandleToggleChanged">
            <MudToggleItem Value="true" Disabled="true">
                <MudIcon Icon="@Icons.Material.Filled.ViewModule"
                         style="@($"color : {(renderWorkOrderCard ? Colors.Shades.White : Colors.Teal.Darken4)};")"
                         Size="Size.Small" />
            </MudToggleItem>
            <MudToggleItem Value="false">
                <MudIcon Icon="@Icons.Material.Filled.ViewList"
                         style="@($"color : {(renderWorkOrderCard ? Colors.Teal.Darken4 : Colors.Shades.White)};")"
                         Size="Size.Small" />
            </MudToggleItem>
        </MudToggleGroup>
    </MudGrid>

    <MudDivider Class="my-2" Style="border-color: black;" />

    @if (_isLoading)
    {
        <div class="d-flex flex-column align-items-center justify-content-center" style="height: 200px;">
            <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
            <MudText Typo="Typo.h6" Style="margin-top:30px">Cargando órdenes de trabajo...</MudText>
        </div>
    }
    else if ((_filteredWorkOrderList is null || !_filteredWorkOrderList.Any()) && (ViewModel.WorkOrderPaginatedList is null || !ViewModel.WorkOrderPaginatedList.Any()))
    {
        <MudItem xs="12">
            <div class="empty-state-card">
                <div class="empty-state-content">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="empty-state-icon" />
                    <MudText Typo="Typo.h6" Class="empty-state-title">No se han encontrado ordenes.</MudText>
                    <MudText Typo="Typo.body1" Class="empty-state-description">
                        Ninguna orden cumple con el criterio de busqueda.
                    </MudText>
                </div>
            </div>
        </MudItem>
    }
    else
    {
        if (renderWorkOrderCard)
        {
            <MudGrid spacing="3" justify="Justify.FlexStart" class="mt-1">
                @foreach (var workorder in _filteredWorkOrderList)
                {
                    <MudItem xs="12" sm="12" md="6" lg="3">
                        <WorkOrderCard InfoWO="workorder" />
                    </MudItem>
                }
                @if (ViewModel.TotalItems > ViewModel.PageSize)
                {
                    <div class="w-100 d-flex flex-column align-items-center mt-4">
                        <MudPagination variant="Variant.Filled"
                                       color="Color.Primary"
                                       count="@((int)Math.Ceiling((double)ViewModel.TotalItems / ViewModel.PageSize))"
                                       selected="@ViewModel.CurrentPage"
                                       selectedchanged="ViewModel.OnPageChanged" />
                    </div>
                }
            </MudGrid>
        }
        else
        {
            <MudItem xs="12" lg="12">
                <WorkOrderTable WorkOrderList="@_filteredWorkOrderList" />
            </MudItem>
        }
    }
</div>
@code{
    [Inject] public LoadWorkOrdersViewModel ViewModel { get; set; }
    [Inject] public TextAppBarStateService TextApp { get; set; }

    private bool renderWorkOrderCard = false;
    private bool _isLoading = true;
    private List<ShowWorkOrderDTO> _filteredWorkOrderList;
    protected override async Task OnInitializedAsync()
    {
        TextApp.PageTitle = "Ordenes de Trabajo";
        await LoadDataAsync();
        _filteredWorkOrderList = ViewModel.AllWorkOrderList;
    }

    private async Task HandleToggleChanged(bool value)
    {
        renderWorkOrderCard = value;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        // Llama a StateHasChanged para mostrar el indicador de carga
        StateHasChanged();

        if (renderWorkOrderCard)
        {
            await ViewModel.LoadWorkOrderListPaginated();
        }
        else
        {
            await ViewModel.LoadWorkOrderList();
        }

        _isLoading = false;
        // Llama a StateHasChanged para renderizar los datos
        StateHasChanged();
    }
    private void HandleFilterSelected(StatsCard.FilterWorkOrder filter)
    {
        // Aplica la lógica de filtrado en el componente padre.
        switch (filter)
        {
            case StatsCard.FilterWorkOrder.Active:
                _filteredWorkOrderList = ViewModel.AllWorkOrderList.Where(wo => wo.Status == "Activo").ToList();
                break;
            case StatsCard.FilterWorkOrder.Pending:
                _filteredWorkOrderList = ViewModel.AllWorkOrderList.Where(wo => wo.Status == "Pendiente").ToList();
                break;
            case StatsCard.FilterWorkOrder.Closed:
                _filteredWorkOrderList = ViewModel.AllWorkOrderList.Where(wo => wo.Status == "Cerrado").ToList();
                break;
            case StatsCard.FilterWorkOrder.None:
            default:
                _filteredWorkOrderList = ViewModel.AllWorkOrderList;
                break;
        }
        StateHasChanged();
    }
}
<style>
    /* Empty State Styles */
    .empty-state-card {
        background: #f8fafc;
        border-radius: 16px;
        padding: 3rem 2rem;
        border: 1px solid #e2e8f0;
        margin: 1rem 0;
        transition: all 0.3s ease;
    }

    .empty-state-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 1rem;
    }

    .empty-state-icon {
        font-size: 48px !important;
        color: #94a3b8 !important;
        opacity: 0.7;
        margin-bottom: 0.5rem;
    }

    .empty-state-title {
        color: #475569 !important;
        font-weight: 600 !important;
        margin: 0 !important;
    }

    .empty-state-description {
        color: #64748b !important;
        max-width: 400px !important;
        line-height: 1.6 !important;
        margin: 0 !important;
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .empty-state-card

    {
        padding: 2rem 1.5rem;
    }

    .empty-state-icon {
        font-size: 40px !important;
    }

    .empty-state-description {
        max-width: 300px !important;
        font-size: 0.9rem !important;
    }

    }

    @@media (max-width: 480px) {
        .empty-state-card

    {
        padding: 1.5rem 1rem;
        margin: 0.5rem 0;
    }

    .empty-state-icon {
        font-size: 36px !important;
    }

    }
</style>


