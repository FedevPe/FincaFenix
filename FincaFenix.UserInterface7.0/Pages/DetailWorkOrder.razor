@page "/ordentrabajo/{IdWorkOrder:int}/detalle/"
@using FincaFenix.ViewModels.ViewModels.WorkOrder.GetInformationWorkOrder
@attribute [Authorize]

<div class="work-order-detail-page">
    @if (ViewModel.IsLoading)
    {
        <div class="loading-container">
            <div class="loading-content">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h6" Class="loading-text">Cargando información de la orden...</MudText>
            </div>
        </div>
    }
    else if (ViewModel.ErrorMessage != null)
    {
        <div class="error-container">
            <MudAlert Severity="MudBlazor.Severity.Error" Class="error-alert">
                <div class="error-content">
                    <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Class="error-icon" />
                    <div>
                        <MudText Typo="Typo.h6">Error al cargar la orden de trabajo</MudText>
                        <MudText Typo="Typo.body2">@ViewModel.ErrorMessage</MudText>
                    </div>
                </div>
            </MudAlert>
        </div>
    }
    else
    {
        <!-- Header Section with Work Order Info and Actions (sin modificar) -->
        <div class="page-header">
            <div class="header-grid">
                <div class="main-info-section">
                    <GeneralInformationWorkOrder InfoWO="@ViewModel.WOInfo"/>
                </div>
                <AuthorizeView Roles="admin, desarrollador, supervisor">
                    <div class="actions-section">
                        <DetailWorkOrderActions InfoWO="@ViewModel.WOInfo" OnStateChanged="HandleStateChange" />
                    </div>
                </AuthorizeView>
            </div>
        </div>

        <!-- Tabs Section -->
        <div class="tabs-container">
            <!-- Tab Headers -->            
            <div class="tabs-header">
                <button class="tab-button @GetTabActiveClass(WorkOrderTab.Activities)"
                        @onclick="() => SetActiveTab(WorkOrderTab.Activities)">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="tab-icon" />
                    <span class="tab-label">Registro de Actividades</span>
                </button>                
                @if(ViewModel.WOInfo.Recipe != null)
                {
                    <button class="tab-button @GetTabActiveClass(WorkOrderTab.Recipe)" 
                            @onclick="() => SetActiveTab(WorkOrderTab.Recipe)">
                        <MudIcon Icon="@Icons.Material.Filled.Science" Class="tab-icon" />
                        <span class="tab-label">Receta</span>
                    </button>

                    <AuthorizeView Roles="admin, desarrollador, supervisor">
                        <!-- Pestañas futuras (deshabilitadas por ahora) -->
                        <button class="tab-button @GetTabActiveClass(WorkOrderTab.Consumption)"
                                @onclick="() => SetActiveTab(WorkOrderTab.Consumption)">
                            <MudIcon Icon="@Icons.Material.Filled.BarChart" Class="tab-icon" />
                            <span class="tab-label">Consumos</span>
                        </button>
                    </AuthorizeView>
                }

                <AuthorizeView Roles="admin, desarrollador, supervisor">
                    <button class="tab-button @GetTabActiveClass(WorkOrderTab.CosumptionSector)"
                            @onclick="() => SetActiveTab(WorkOrderTab.CosumptionSector)">
                        <MudIcon Icon="@Icons.Material.Filled.Fullscreen" Class="tab-icon" />
                        <span class="tab-label">Cuadros trabajados</span>
                    </button>
                </AuthorizeView>

                <AuthorizeView Roles="desarrollador">
                    <!-- Pestañas futuras (deshabilitadas por ahora) -->
                    <button class="tab-button tab-button-disabled" disabled>
                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="tab-icon" />
                        <span class="tab-label">Informes</span>
                    </button>
                </AuthorizeView>
            </div>

            <!-- Tab Content -->
            <div class="tab-content" id="data">
                @if (activeTab == WorkOrderTab.Activities)
                {
                    <div class="tab-panel">
                        
                        <div class="tab-panel-content">
                            @if (ViewModel.WOInfo.DetailsWorkOrder != null && ViewModel.WOInfo.DetailsWorkOrder.Any())
                            {
                                <ActivityLog ActivityList="ViewModel.WOInfo.DetailsWorkOrder"/>
                            }
                            else
                            {
                                <div class="empty-state-card">
                                    <div class="empty-state-content">
                                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="empty-state-icon" />
                                        <MudText Typo="Typo.h6" Class="empty-state-title">Sin actividades registradas</MudText>
                                        <MudText Typo="Typo.body1" Class="empty-state-description">
                                            Aún no se han registrado actividades para esta orden de trabajo.
                                        </MudText>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (activeTab == WorkOrderTab.Recipe)
                {
                    <div class="tab-panel">                 
                        <div class="tab-panel-content">
                            @if (ViewModel.WOInfo.Recipe != null && ViewModel.WOInfo.Recipe.Details != null && ViewModel.WOInfo.Recipe.Details.Any())
                            {
                                <DetailRecipe Recipe="ViewModel.WOInfo.Recipe" TotalAreaWorked="ViewModel.WOInfo.TotalAreaWorked"/>
                            }
                            else
                            {
                                <div class="empty-state-card">
                                    <div class="empty-state-content">
                                        <MudIcon Icon="@Icons.Material.Filled.Science" Class="empty-state-icon" />
                                        <MudText Typo="Typo.h6" Class="empty-state-title">Sin receta asociada</MudText>
                                        <MudText Typo="Typo.body1" Class="empty-state-description">
                                            No hay una receta de productos asociada a esta orden de trabajo.
                                        </MudText>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (activeTab == WorkOrderTab.Consumption)
                {
                    <AuthorizeView Roles="admin, desarrollador, supervisor">
                        <div class="tab-panel">
                            <div class="tab-panel-content">
                                @if (ViewModel.WOInfo.Recipe != null && ViewModel.WOInfo.Recipe.Details != null && ViewModel.WOInfo.Recipe.Details.Any() && ViewModel.WOInfo.DetailsWorkOrder != null && ViewModel.WOInfo.DetailsWorkOrder.Any())
                                {
                                    <RecipeConsumption DetailWorkOrderList="ViewModel.WOInfo.DetailsWorkOrder" Recipe="ViewModel.WOInfo.Recipe" TotalAreaWorked="ViewModel.WOInfo.TotalAreaWorked"/>
                                }
                                else
                                {
                                    <div class="empty-state-card">
                                        <div class="empty-state-content">
                                            <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="empty-state-icon" />
                                            <MudText Typo="Typo.h6" Class="empty-state-title">Sin datos asociados</MudText>
                                            <MudText Typo="Typo.body1" Class="empty-state-description">
                                                Aún no es posible visualizar los datos por falta de registros.
                                            </MudText>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </AuthorizeView>
                }
                else if (activeTab == WorkOrderTab.CosumptionSector)
                {
                    <AuthorizeView Roles="admin, desarrollador, supervisor">
                        <div class="tab-panel">
                            <div class="tab-panel-content">
                                @if (ViewModel.WOInfo.Recipe != null && ViewModel.WOInfo.Recipe.Details != null && ViewModel.WOInfo.Recipe.Details.Any() && ViewModel.WOInfo.DetailsWorkOrder != null && ViewModel.WOInfo.DetailsWorkOrder.Any())
                                {
                                    <ReportsComponent SectorList="ViewModel.WOInfo.SectorList" DetailWorkOrderDTO="ViewModel.WOInfo.DetailsWorkOrder" Recipe="ViewModel.WOInfo.Recipe" />
                                }
                                else
                                {
                                    <div class="empty-state-card">
                                        <div class="empty-state-content">
                                            <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="empty-state-icon" />
                                            <MudText Typo="Typo.h6" Class="empty-state-title">Sin datos asociados</MudText>
                                            <MudText Typo="Typo.body1" Class="empty-state-description">
                                                Aún no se pueden mostrar gráficas. No se han registrado actividades.
                                            </MudText>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </AuthorizeView>
                }
            </div>
        </div>
    }
</div>
@code{
    [Inject] private GeneralInfoWorkOrderViewModel ViewModel { get; set; }
    [Inject] private IJSRuntime JSRuntime { get; set; }
    [Inject] private LoadDetailsWorkOrderViewModel DetailsVM { get; set; }
    [Inject] public TextAppBarStateService TextApp { get; set; }
    [Inject] public NavigationManager NavigationManager { get; set; }
    [Parameter] public int IdWorkOrder { get; set; }

    protected override async Task OnInitializedAsync()
    {
        TextApp.PageTitle = "Detalle de la orden de trabajo";
        await ViewModel.LoadDataWorkOrderById(IdWorkOrder);
        await DetailsVM.LoadActivityLog(IdWorkOrder);
        await Task.Delay(1500);
        StateHasChanged();
    }
    private async Task HandleStateChange()
    {
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
        StateHasChanged();
        await Task.CompletedTask;
    }
    // Enum para las pestañas
    public enum WorkOrderTab
    {
        Activities,
        Recipe,
        Consumption,
        CosumptionSector
    }

    private WorkOrderTab activeTab = WorkOrderTab.Activities;

    private async Task SetActiveTab(WorkOrderTab tab)
    {
        activeTab = tab;
        await Task.Delay(50);
        await ScrollToElement("data");
    }

    private async Task ScrollToElement(string elementId)
    {
        await JSRuntime.InvokeVoidAsync("scrollToElement", elementId);
    }

    private string GetTabActiveClass(WorkOrderTab tab)
    {
        return activeTab == tab ? "active" : "";
    }
}
<style>
    /* Estilos base existentes */
    .work-order-detail-page {
        background: #f8fafc;
    }

    .loading-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        padding: 2rem;
    }

    .loading-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        padding: 3rem;
        background: white;
        border-radius: 20px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    }

    .loading-text {
        color: #64748b !important;
        font-weight: 500 !important;
        margin: 0 !important;
    }

    .error-container {
        padding: 2rem;
        display: flex;
        justify-content: center;
    }

    .error-alert {
        max-width: 600px;
        border-radius: 16px !important;
        padding: 1.5rem !important;
    }

    .error-content {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
    }

    .error-icon {
        font-size: 24px !important;
        color: #ef4444;
        margin-top: 0.25rem;
    }

    /* Header Section (sin cambios) */
    .page-header {
        margin-bottom: 2rem;
        width: 100%;
    }

    .header-grid {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 1rem;
        align-items: start;
    }

    .main-info-section {
        min-width: 0;
        width: 100%;
        height: 100%;
    }

    .actions-section {
        width: 350px;
        height: 100%;
        flex-shrink: 0;
    }

    /* Nuevos estilos para el sistema de pestañas */
    .tabs-container {
        background: white;
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .tabs-header {
        display: flex;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        overflow-x: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

        .tabs-header::-webkit-scrollbar {
            display: none;
        }

    .tab-button {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1.25rem 1.75rem;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 16px;
        font-weight: 500;
        color: #64748b;
        transition: all 0.3s ease;
        position: relative;
        border-bottom: 3px solid transparent;
        white-space: nowrap;
        flex-shrink: 0;
    }

        .tab-button:hover:not(.tab-button-disabled) {
            background: rgba(0, 121, 107, 0.05);
            color: #00796B;
        }

        .tab-button.active {
            color: #00796B;
            background: white;
            border-bottom-color: #00796B;
            font-weight: 600;
        }

    .tab-button-disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .tab-icon {
        font-size: 20px !important;
    }

    .tab-label {
        font-size: inherit;
        font-weight: inherit;
    }

    .tab-content {
        min-height: 400px;
    }

    .tab-panel {
        padding: 1rem;
    }

    .tab-panel-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .panel-icon {
        font-size: 28px !important;
        color: #00796B;
    }

    .panel-title {
        color: #1e293b !important;
        font-weight: 600 !important;
        margin: 0 !important;
    }

    .tab-panel-content {
        background: transparent;
    }

    /* Empty State Styles (mejorados) */
    .empty-state-card {
        background: #f8fafc;
        border-radius: 16px;
        padding: 3rem 2rem;
        border: 1px solid #e2e8f0;
        margin: 1rem 0;
    }

    .empty-state-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 1rem;
    }

    .empty-state-icon {
        font-size: 48px !important;
        color: #94a3b8;
        opacity: 0.7;
    }

    .empty-state-title {
        color: #475569 !important;
        font-weight: 600 !important;
        margin: 0 !important;
    }

    .empty-state-description {
        color: #64748b !important;
        max-width: 400px !important;
        line-height: 1.6 !important;
        margin: 0 !important;
    }

    /* Responsive Design */
    @@media (max-width: 1200px) {
        .actions-section {
            width: 320px;
        }
    }

    @@media (max-width: 968px) {
        .header-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .actions-section {
            width: 100%;
        }

        .tab-button {
            padding: 1rem 1.25rem;
            font-size: 14px;
        }

        .tab-icon {
            font-size: 18px !important;
        }

        .tab-panel {
            padding: 1.5rem;
        }
    }

    @@media (max-width: 768px) {
        .work-order-detail-page {
            padding: 0.5rem;
        }

        .page-header {
            margin-bottom: 1.5rem;
        }

        .tabs-container {
            border-radius: 16px;
        }

        .tab-button {
            padding: 0.875rem 1rem;
            gap: 0.5rem;
        }

        .tab-panel-header {
            margin-bottom: 1rem;
        }

        .panel-icon {
            font-size: 24px !important;
        }

        .empty-state-card {
            padding: 2rem 1.5rem;
        }

        .empty-state-icon {
            font-size: 40px !important;
        }
    }

    @@media (max-width: 480px) {
        .loading-content {
            padding: 2rem 1.5rem;
        }

        .tab-button {
            padding: 0.75rem 0.875rem;
        }

        .tab-label {
            display: none; /* Ocultar labels en pantallas muy pequeñas */
        }

        .tab-panel {
            padding: 1rem;
        }

        .tab-panel-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
        }

        .empty-state-card {
            padding: 1.5rem 1rem;
        }
    }

    /* Animaciones suaves para transiciones de contenido */
    .tab-panel {
        animation: fadeIn 0.3s ease-in-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>